.cyber-fortune-page {
  min-height: 100vh;
  background-color: #050505;
  color: #00f2ff;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
}

/* 背景粒子 */
.bg-particles {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

.particle {
  position: absolute;
  width: 2rpx;
  height: 40rpx;
  background: linear-gradient(to bottom, transparent, #00f2ff);
  opacity: 0.3;
  animation: fall linear infinite;
}

@keyframes fall {
  0% { transform: translateY(-100rpx); opacity: 0; }
  50% { opacity: 0.5; }
  100% { transform: translateY(120vh); opacity: 0; }
}

/* 头部标题 */
.cyber-header {
  margin-top: 80rpx;
  text-align: center;
  z-index: 10;
}

.glitch-title {
  font-size: 64rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
  position: relative;
  text-shadow: 0 0 10rpx rgba(0, 242, 255, 0.5);
}

.glitch-title::before,
.glitch-title::after {
  content: attr(data-text);
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.8;
}

.glitch-title::before {
  color: #ff00ff;
  z-index: -1;
  animation: glitch-anim 2s infinite linear alternate-reverse;
}

.glitch-title::after {
  color: #00ffff;
  z-index: -2;
  animation: glitch-anim2 3s infinite linear alternate-reverse;
}

@keyframes glitch-anim {
  0% { clip: rect(10px, 9999px, 20px, 0); transform: translate(-2px, -2px); }
  20% { clip: rect(30px, 9999px, 40px, 0); transform: translate(2px, 2px); }
  100% { clip: rect(10px, 9999px, 20px, 0); transform: translate(-2px, -2px); }
}

@keyframes glitch-anim2 {
  0% { clip: rect(40px, 9999px, 50px, 0); transform: translate(2px, 2px); }
  20% { clip: rect(10px, 9999px, 20px, 0); transform: translate(-2px, -2px); }
  100% { clip: rect(40px, 9999px, 50px, 0); transform: translate(2px, 2px); }
}

.cyber-subtitle {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  opacity: 0.6;
  margin-top: 10rpx;
}

/* 主场景 */
.main-scene {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 5;
}

/* 签筒 */
.cylinder-container {
  position: relative;
  width: 240rpx;
  height: 400rpx;
  perspective: 1000px;
  transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.cylinder {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
}

.cylinder-body {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1a1a1a 0%, #333 50%, #1a1a1a 100%);
  border: 4rpx solid #444;
  border-radius: 20rpx;
  position: relative;
  box-shadow: 0 0 30rpx rgba(0, 0, 0, 0.8), inset 0 0 20rpx rgba(0, 242, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.neon-ring {
  position: absolute;
  left: -10rpx;
  right: -10rpx;
  height: 6rpx;
  background: #00f2ff;
  box-shadow: 0 0 15rpx #00f2ff;
}

.neon-ring.top { top: 40rpx; }
.neon-ring.bottom { bottom: 40rpx; }

.cylinder-text {
  font-size: 100rpx;
  font-weight: 900;
  color: #00f2ff;
  text-shadow: 0 0 20rpx #00f2ff;
  opacity: 0.8;
}

/* 摇动动画 */
.cylinder-container.shaking {
  animation: cyber-shake 0.1s infinite;
}

@keyframes cyber-shake {
  0% { transform: translate(2px, 1px) rotate(0deg); }
  10% { transform: translate(-1px, -2px) rotate(-1deg); }
  20% { transform: translate(-3px, 0px) rotate(1deg); }
  30% { transform: translate(3px, 2px) rotate(0deg); }
  40% { transform: translate(1px, -1px) rotate(1deg); }
  50% { transform: translate(-1px, 2px) rotate(-1deg); }
  60% { transform: translate(-3px, 1px) rotate(0deg); }
  70% { transform: translate(3px, 1px) rotate(-1deg); }
  80% { transform: translate(-1px, -1px) rotate(1deg); }
  90% { transform: translate(1px, 2px) rotate(0deg); }
  100% { transform: translate(1px, -2px) rotate(-1deg); }
}

/* 签位弹出 */
.fortune-stick {
  position: absolute;
  top: 0;
  left: 50%;
  width: 30rpx;
  height: 200rpx;
  background: linear-gradient(to bottom, #ffd700, #b8860b);
  margin-left: -15rpx;
  z-index: -1;
  opacity: 0;
  transform: translateY(0);
  transition: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.fortune-stick.emerge {
  opacity: 1;
  transform: translateY(-250rpx);
  z-index: 20;
}

.fortune-stick.floating {
  animation: stick-float 3s infinite ease-in-out;
}

@keyframes stick-float {
  0%, 100% { transform: translateY(-250rpx) scale(1.1) rotate(0deg); box-shadow: 0 0 20rpx rgba(0, 242, 255, 0.5); }
  50% { transform: translateY(-280rpx) scale(1.2) rotate(5deg); box-shadow: 0 0 40rpx rgba(0, 242, 255, 0.8); }
}

.stick-glow {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  box-shadow: 0 0 20rpx #00f2ff;
  opacity: 0.6;
}

/* 提示文字 */
.interaction-hint {
  margin-top: 60rpx;
  position: relative;
  padding: 10rpx 40rpx;
  border: 1rpx solid rgba(0, 242, 255, 0.3);
  transition: opacity 0.3s;
}

.interaction-hint.hidden { opacity: 0; }

.hint-text {
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: #00f2ff;
  text-transform: uppercase;
}

.scan-line {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: #00f2ff;
  box-shadow: 0 0 10rpx #00f2ff;
  animation: scan 2s infinite linear;
}

@keyframes scan {
  0% { top: 0; }
  100% { top: 100%; }
}

/* 卷轴遮罩 */
.scroll-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.5s;
}

.scroll-overlay.visible {
  opacity: 1;
  pointer-events: auto;
}

.digital-scroll {
  width: 85%;
  background: #0a0a0a;
  border: 2rpx solid #00f2ff;
  box-shadow: 0 0 50rpx rgba(0, 242, 255, 0.3);
  transform: scaleY(0);
  transform-origin: center;
  transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  display: flex;
  flex-direction: column;
}

.digital-scroll.unfolding {
  transform: scaleY(1);
}

.scroll-header {
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(0, 242, 255, 0.2);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.scroll-title-glitch {
  font-size: 40rpx;
  font-weight: 800;
  color: #00f2ff;
}

.scroll-id {
  font-size: 18rpx;
  opacity: 0.5;
  font-family: monospace;
}

.scroll-body {
  padding: 60rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.fortune-main-text {
  font-size: 48rpx;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 60rpx;
  color: #fff;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
}

.monospace {
  font-family: 'Courier New', Courier, monospace;
}

.fortune-details {
  display: flex;
  justify-content: space-around;
  border-top: 1rpx dashed rgba(0, 242, 255, 0.3);
  padding-top: 40rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-item .label {
  font-size: 28rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.detail-item.good .label {
  background: rgba(0, 255, 0, 0.2);
  color: #00ff00;
  border: 1rpx solid #00ff00;
}

.detail-item.bad .label {
  background: rgba(255, 0, 0, 0.2);
  color: #ff0000;
  border: 1rpx solid #ff0000;
}

.detail-item .val {
  font-size: 40rpx;
  font-weight: 900;
  text-shadow: 0 0 10rpx currentColor;
}

.detail-item.good .val { color: #00ff00; }
.detail-item.bad .val { color: #ff0000; }

.light-streak {
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(0, 242, 255, 0.2), transparent);
  animation: streak 2s infinite;
}

@keyframes streak {
  0% { left: -100%; }
  100% { left: 100%; }
}

.scroll-footer {
  padding: 30rpx;
  text-align: center;
  font-size: 24rpx;
  opacity: 0.5;
  border-top: 1rpx solid rgba(0, 242, 255, 0.1);
}

/* 装饰元素 */
.cyber-decor {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #00f2ff;
  z-index: 10;
}

.top-left { top: 40rpx; left: 40rpx; border-right: none; border-bottom: none; }
.top-right { top: 40rpx; right: 40rpx; border-left: none; border-bottom: none; }
.bottom-left { bottom: 40rpx; left: 40rpx; border-right: none; border-top: none; }
.bottom-right { bottom: 40rpx; right: 40rpx; border-left: none; border-top: none; }
