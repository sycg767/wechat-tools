@import "../../app.wxss";

.bagua-page { padding-bottom: 48rpx; }
.card { margin-bottom: 24rpx; padding: 26rpx; }
.section-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; margin-bottom: 22rpx; }
.section-head.compact { margin-bottom: 16rpx; }
.section-title { display: block; color: var(--text-main); font-size: 32rpx; font-weight: 800; line-height: 1.25; }
.section-subtitle { display: block; margin-top: 8rpx; color: var(--text-light); font-size: 23rpx; line-height: 1.35; }
.trigram-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12rpx; }
.trigram { padding: 16rpx 8rpx; border-radius: 20rpx; background: var(--card-subtle); text-align: center; box-sizing: border-box; }
.trigram-symbol { display: block; color: var(--text-main); font-size: 44rpx; line-height: 1; }
.trigram-name { display: block; margin-top: 8rpx; color: var(--text-main); font-size: 22rpx; font-weight: 800; }
.trigram-trait { display: block; margin-top: 4rpx; color: var(--text-light); font-size: 20rpx; }
.label { display: block; margin-bottom: 12rpx; color: var(--text-main); font-size: 28rpx; font-weight: 800; }
.input { width: 100%; min-height: 148rpx; padding: 20rpx 22rpx; border-radius: 22rpx; background: var(--card-subtle); color: var(--text-main); font-size: 27rpx; line-height: 1.5; box-sizing: border-box; }
.primary-action, .copy-btn, .history-copy { display: flex; align-items: center; justify-content: center; margin: 0; padding: 0; border-radius: 999rpx; line-height: 1; box-sizing: border-box; }
.primary-action { width: 100%; height: 76rpx; margin-top: 20rpx; background: var(--text-main); color: #fff; font-size: 28rpx; font-weight: 800; }
.copy-btn, .history-copy { flex-shrink: 0; min-width: 88rpx; height: 44rpx; padding: 0 18rpx; background: var(--card-subtle); color: var(--text-second); font-size: 22rpx; font-weight: 600; }
.result-head .copy-btn { position: absolute; top: 0; right: 0; }
.primary-action::after, .copy-btn::after, .history-copy::after { border: none; }
.result-head { position: relative; margin-bottom: 22rpx; }
.result-title-block { width: 100%; min-width: 0; padding-right: 112rpx; box-sizing: border-box; }
.hex-name { display: block; color: var(--text-main); font-size: 40rpx; font-weight: 900; line-height: 1.2; }
.date { display: block; margin-top: 8rpx; color: var(--text-light); font-size: 24rpx; line-height: 1.45; }
.question-text { display: block; width: 100%; margin-top: 6rpx; color: var(--text-second); font-size: 25rpx; line-height: 1.45; white-space: normal; word-break: normal; overflow-wrap: anywhere; }
.hex-symbol { width: 220rpx; margin: 26rpx auto 22rpx; }
.line-row { position: relative; display: flex; align-items: center; justify-content: center; height: 24rpx; margin: 12rpx 0; }
.line-part { height: 14rpx; border-radius: 999rpx; background: var(--text-main); }
.line-row.yang .line-part { width: 168rpx; }
.line-row.yin .line-part { width: 70rpx; }
.line-gap { width: 28rpx; height: 1rpx; }
.moving-dot { position: absolute; right: -26rpx; top: 50%; transform: translateY(-50%); display: flex; align-items: center; justify-content: center; width: 34rpx; height: 34rpx; border-radius: 999rpx; background: var(--text-main); color: #fff; font-size: 18rpx; font-weight: 800; }
.hex-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 10rpx; margin-bottom: 18rpx; }
.hex-tags text { display: inline-flex; align-items: center; min-height: 40rpx; padding: 0 16rpx; border-radius: 999rpx; background: var(--card-subtle); color: var(--text-second); font-size: 22rpx; }
.hex-summary { padding: 20rpx; border-radius: 22rpx; background: var(--card-subtle); color: var(--text-second); font-size: 26rpx; line-height: 1.7; }
.hex-card-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; }
.hex-info-card { margin-bottom: 0; }
.card-label { display: inline-flex; align-items: center; min-height: 38rpx; padding: 0 14rpx; border-radius: 999rpx; background: var(--text-main); color: #fff; font-size: 21rpx; font-weight: 800; }
.hex-card-title { display: block; margin-top: 16rpx; color: var(--text-main); font-size: 30rpx; font-weight: 900; line-height: 1.3; }
.hex-card-sub { display: block; margin-top: 8rpx; color: var(--text-light); font-size: 23rpx; }
.hex-card-text { display: block; margin-top: 14rpx; color: var(--text-second); font-size: 25rpx; line-height: 1.65; }
.hex-card-text.muted { color: var(--text-light); font-size: 23rpx; }
.moving-item { padding: 18rpx 0; border-bottom: 1rpx solid rgba(15, 23, 42, .08); }
.moving-item:last-child { border-bottom: 0; padding-bottom: 0; }
.moving-label { display: inline-flex; align-items: center; min-height: 40rpx; padding: 0 14rpx; border-radius: 999rpx; background: var(--card-subtle); color: var(--text-main); font-size: 22rpx; font-weight: 800; }
.moving-text { display: block; margin-top: 12rpx; color: var(--text-second); font-size: 25rpx; line-height: 1.65; }
.advice-card { display: flex; flex-direction: column; gap: 14rpx; }
.advice-row { padding: 18rpx 20rpx; border-radius: 20rpx; background: var(--card-subtle); }
.advice-row.caution { background: #fff7ed; }
.advice-label { display: block; color: var(--text-main); font-size: 24rpx; font-weight: 800; }
.advice-text { display: block; margin-top: 8rpx; color: var(--text-second); font-size: 25rpx; line-height: 1.6; }
.history-item { padding: 20rpx; border-radius: 20rpx; background: var(--card-subtle); margin-bottom: 14rpx; }
.history-item:last-child { margin-bottom: 0; }
.history-top { display: flex; align-items: flex-start; gap: 16rpx; }
.history-title { flex: 1; min-width: 0; color: var(--text-main); font-size: 25rpx; font-weight: 800; line-height: 1.45; }
.history-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 10rpx; margin-top: 14rpx; }
.history-badge { display: inline-flex; align-items: center; min-height: 38rpx; padding: 0 14rpx; border-radius: 999rpx; background: #fff; color: var(--text-second); font-size: 21rpx; }
.history-arrow { color: var(--text-light); font-size: 22rpx; }
.history-date { margin-left: auto; color: var(--text-light); font-size: 22rpx; }
.disclaimer { margin: 22rpx 0 24rpx; padding: 18rpx 20rpx; border-radius: 18rpx; background: #fff; color: var(--text-light); font-size: 23rpx; line-height: 1.6; }

.ai-card { margin-bottom: 24rpx; }
.ai-loading { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 20rpx 0; }
.ai-loading-text { color: var(--text-light); font-size: 24rpx; }
.ai-head { margin-bottom: 16rpx; }
.ai-text { display: block; width: 100%; box-sizing: border-box; overflow: visible; }
.ai-hint-card { display: flex; flex-direction: column; align-items: center; gap: 14rpx; text-align: center; }
.ai-hint { color: var(--text-light); font-size: 24rpx; line-height: 1.6; }
.ai-config-btn { display: inline-flex; align-items: center; justify-content: center; min-width: 140rpx; height: 60rpx; margin: 0; padding: 0 28rpx; border-radius: 999rpx; background: var(--text-main); color: #fff; font-size: 24rpx; font-weight: 800; line-height: 1; }
.ai-config-btn::after { border: none; }
