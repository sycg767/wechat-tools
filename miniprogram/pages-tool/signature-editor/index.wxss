@import "../../app.wxss";

page {
  background: #EEF1F5;
}

.editor-page {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.editor-shell {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: calc(28rpx + env(safe-area-inset-top)) 28rpx 184rpx;
  box-sizing: border-box;
}

.editor-topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.topbar-side {
  min-width: 88rpx;
  padding-top: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.topbar-side-placeholder {
  visibility: hidden;
}

.topbar-title-wrap {
  flex: 1;
  text-align: center;
}

.topbar-title {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
  color: var(--text-main);
}

.topbar-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-second);
}

.color-picker {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin: 28rpx 0 24rpx;
}

.color-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}

.color-item.active {
  border-color: var(--text-main);
  transform: scale(1.08);
}

.canvas-panel {
  position: relative;
  flex: 1;
  min-height: 0;
  border-radius: 40rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F8F9FB 100%);
  box-shadow: 0 18rpx 46rpx rgba(15, 23, 42, 0.08);
  border: 1px solid rgba(17, 24, 39, 0.05);
  overflow: hidden;
}

.signature-canvas {
  width: 100%;
  height: 100%;
}

.canvas-placeholder {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 30rpx;
  color: #C0C6D0;
  pointer-events: none;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  box-shadow: 0 -8rpx 30rpx rgba(15, 23, 42, 0.06);
  z-index: 100;
}

.action-buttons {
  display: flex;
  gap: 18rpx;
}

.action-buttons .btn {
  flex: 1;
}

.secondary-btn {
  background: #FFFFFF;
}
