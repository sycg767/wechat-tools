<view class="container">
  <view class="page-header">
    <view class="page-title">字数统计</view>
    <view class="page-desc">中英文、标点、行数与字节数实时统计</view>
  </view>

  <view class="card form-card">
    <view class="textarea-wrap">
      <textarea
        class="textarea"
        placeholder="输入或粘贴文本..."
        value="{{text}}"
        bindinput="onInput"
        auto-height
        maxlength="-1"
      />
    </view>
    <view class="action-row">
      <button class="btn btn-secondary btn-sm" bindtap="handleClear" hover-class="btn-hover">清空</button>
      <button class="btn btn-primary btn-sm" bindtap="handleCopy" hover-class="btn-hover">复制全文</button>
    </view>
  </view>

  <view class="card stats-card">
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{chars}}</view>
        <view class="stat-label">总字符</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{cnChars}}</view>
        <view class="stat-label">中文字</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{enWords}}</view>
        <view class="stat-label">英文词</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{digits}}</view>
        <view class="stat-label">数字</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{puncts}}</view>
        <view class="stat-label">标点</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{spaces}}</view>
        <view class="stat-label">空格</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{lines}}</view>
        <view class="stat-label">行数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{bytes}}</view>
        <view class="stat-label">字节(UTF-8)</view>
      </view>
    </view>
  </view>
</view>
