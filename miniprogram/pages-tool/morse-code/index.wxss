@import "../../app.wxss";

.morse-page { padding-bottom: 48rpx; }
.morse-hero { display: block; }
.panel-card { padding: 26rpx; }
.mode-switch { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16rpx; margin-bottom: 28rpx; }
.mode-item { min-height: 104rpx; padding: 20rpx; border-radius: 22rpx; background: var(--card-subtle); color: var(--text-second); box-sizing: border-box; border: 2rpx solid transparent; }
.mode-item.active { background: #fff; color: var(--text-main); border-color: var(--text-main); box-shadow: 0 12rpx 30rpx rgba(16, 24, 40, .08); }
.mode-title { display: block; font-size: 28rpx; font-weight: 800; line-height: 1.25; }
.mode-desc { display: block; margin-top: 8rpx; font-size: 20rpx; line-height: 1.35; color: var(--text-light); word-break: break-word; }
.input-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16rpx; margin-bottom: 14rpx; }
.label { font-size: 28rpx; font-weight: 800; color: var(--text-main); }
.input-tip { flex: 1; text-align: right; font-size: 22rpx; line-height: 1.4; color: var(--text-light); }
.textarea { width: 100%; min-height: 210rpx; padding: 22rpx; box-sizing: border-box; border-radius: 22rpx; background: var(--card-subtle); font-size: 28rpx; line-height: 1.55; color: var(--text-main); }
.actions { display: flex; justify-content: flex-end; gap: 14rpx; margin-top: 18rpx; }
.action-btn, .mini-action { display: flex; align-items: center; justify-content: center; margin: 0; padding: 0; border-radius: 999rpx; font-size: 24rpx; line-height: 1; box-sizing: border-box; }
.action-btn { min-width: 132rpx; height: 56rpx; padding: 0 22rpx; font-weight: 700; }
.action-btn.primary { background: var(--text-main); color: #fff; }
.action-btn.ghost { background: var(--card-subtle); color: var(--text-main); }
.action-btn::after, .mini-action::after { border: none; }
.error-list { margin-top: 20rpx; padding: 18rpx 20rpx; border-radius: 18rpx; background: rgba(239, 68, 68, .08); }
.error-item { color: var(--error-color); font-size: 24rpx; line-height: 1.6; }
.result-card, .history-card { margin-top: 28rpx; }
.section-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; margin-bottom: 20rpx; }
.section-head.compact { margin-bottom: 18rpx; }
.section-title { display: block; font-size: 32rpx; font-weight: 800; line-height: 1.25; color: var(--text-main); }
.section-subtitle { display: block; margin-top: 8rpx; font-size: 23rpx; line-height: 1.35; color: var(--text-light); }
.mini-action { min-width: 104rpx; height: 56rpx; padding: 0 20rpx; flex-shrink: 0; background: var(--text-main); color: #fff; font-size: 24rpx; }
.mini-action.light { background: var(--card-subtle); color: var(--text-second); }
.result-box { padding: 22rpx; border-radius: 22rpx; background: #f8fafc; }
.result-text { display: block; font-size: 31rpx; line-height: 1.55; word-break: normal; overflow-wrap: break-word; font-family: ui-monospace, Menlo, Consolas, monospace; color: var(--text-main); }
.rhythm-block { margin-top: 24rpx; padding-top: 22rpx; border-top: 1rpx solid rgba(15, 23, 42, .08); }
.rhythm-title { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-bottom: 16rpx; color: var(--text-second); font-size: 24rpx; font-weight: 700; }
.legend { display: flex; gap: 12rpx; flex-wrap: wrap; justify-content: flex-end; color: var(--text-light); font-size: 20rpx; font-weight: 400; }
.legend text { display: inline-flex; align-items: center; gap: 6rpx; }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 999rpx; }
.legend-dot.dot { background: #475467; }
.legend-dot.dash { width: 30rpx; background: #101828; }
.legend-dot.word { background: #d0d5dd; }
.rhythm { display: flex; flex-wrap: wrap; gap: 8rpx; }
.rhythm-item { min-width: 24rpx; height: 30rpx; padding: 0 8rpx; border-radius: 999rpx; font-size: 18rpx; line-height: 30rpx; text-align: center; background: #e4e7ec; color: var(--text-second); box-sizing: border-box; }
.rhythm-item.dot { width: 30rpx; min-width: 30rpx; padding: 0; background: #475467; color: #fff; }
.rhythm-item.dash { min-width: 70rpx; background: #101828; color: #fff; }
.rhythm-item.word { min-width: 86rpx; background: #d0d5dd; color: #344054; }
.history-item { display: flex; align-items: center; gap: 18rpx; padding: 20rpx 0; border-bottom: 1rpx solid rgba(15, 23, 42, .08); }
.history-item:last-child { border-bottom: 0; padding-bottom: 0; }
.history-main { flex: 1; min-width: 0; }
.history-meta { display: flex; gap: 16rpx; margin-bottom: 8rpx; color: var(--text-light); font-size: 22rpx; }
.history-input { display: block; color: var(--text-main); font-size: 26rpx; line-height: 1.4; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.history-output { display: block; margin-top: 6rpx; font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 23rpx; line-height: 1.35; color: var(--text-second); word-break: normal; overflow-wrap: break-word; }
