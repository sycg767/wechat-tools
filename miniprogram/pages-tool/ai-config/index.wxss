@import "../../app.wxss";

.ai-config-page { padding-bottom: 48rpx; }
.form-item { margin-bottom: 26rpx; }
.form-label { display: block; color: var(--text-main); font-size: 26rpx; font-weight: 800; line-height: 1.35; margin-bottom: 10rpx; }
.form-input { width: 100%; min-height: 72rpx; padding: 0 22rpx; border-radius: 16rpx; background: var(--card-subtle); color: var(--text-main); font-size: 26rpx; line-height: 72rpx; box-sizing: border-box; }
.form-hint { display: block; margin-top: 8rpx; color: var(--text-light); font-size: 22rpx; line-height: 1.4; }
.form-hint-row { display: flex; justify-content: space-between; align-items: center; margin-top: 8rpx; }
.form-toggle-key { color: var(--text-second); font-size: 22rpx; text-decoration: underline; }
.hint-card { background: #fff7ed; }
.hint-title { display: block; color: #9a3412; font-size: 26rpx; font-weight: 800; margin-bottom: 10rpx; }
.hint-item { display: block; color: #9a3412; font-size: 23rpx; line-height: 1.5; margin-top: 6rpx; }
.hint-item.success { color: #15803d; }
.hint-item.fail { color: #b91c1c; }
.actions { display: flex; flex-direction: column; gap: 16rpx; margin-top: 8rpx; }
.primary-action, .secondary-action { display: flex; align-items: center; justify-content: center; height: 76rpx; border-radius: 999rpx; line-height: 1; box-sizing: border-box; margin: 0; }
.primary-action { width: 100%; background: var(--text-main); color: #fff; font-size: 28rpx; font-weight: 800; }
.secondary-action { width: 100%; background: var(--card-subtle); color: var(--text-second); font-size: 26rpx; font-weight: 600; }
.primary-action::after, .secondary-action::after { border: none; }
