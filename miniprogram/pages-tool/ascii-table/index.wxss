@import "../../app.wxss";

.ascii-page { padding-bottom: 48rpx; }
.query-card { display: flex; align-items: center; gap: 12rpx; padding: 18rpx; margin-bottom: 22rpx; }
.input { flex: 1; height: 72rpx; padding: 0 22rpx; box-sizing: border-box; border-radius: 18rpx; background: var(--card-subtle); color: var(--text-main); font-size: 28rpx; }
.clear-btn { flex-shrink: 0; padding: 0 4rpx; color: var(--text-light); font-size: 22rpx; line-height: 72rpx; }
.tabs { margin-bottom: 18rpx; white-space: nowrap; }
.tab { display: inline-flex; align-items: center; justify-content: center; min-height: 56rpx; padding: 0 24rpx; margin-right: 12rpx; border-radius: 999rpx; background: #fff; color: var(--text-second); font-size: 24rpx; box-shadow: var(--shadow-soft); }
.tab.active { background: var(--text-main); color: #fff; }
.summary-row { display: flex; justify-content: space-between; gap: 16rpx; margin: 4rpx 4rpx 18rpx; color: var(--text-light); font-size: 23rpx; }
.ascii-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16rpx; }
.ascii-card { min-height: 180rpx; padding: 18rpx; border-radius: 22rpx; background: #fff; box-shadow: var(--shadow-soft); box-sizing: border-box; }
.char-box { display: flex; align-items: center; justify-content: center; width: 100%; height: 70rpx; margin-bottom: 14rpx; border-radius: 18rpx; background: var(--card-subtle); color: var(--text-main); font-size: 30rpx; font-weight: 800; line-height: 1.2; word-break: break-word; }
.ascii-meta { min-width: 0; }
.ascii-title { display: block; color: var(--text-main); font-size: 25rpx; font-weight: 700; line-height: 1.35; }
.ascii-code { display: block; margin-top: 6rpx; color: var(--text-second); font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 22rpx; line-height: 1.35; word-break: normal; overflow-wrap: break-word; }
.ascii-desc { display: block; margin-top: 6rpx; color: var(--text-light); font-size: 22rpx; line-height: 1.35; }
.empty { padding: 80rpx 0; text-align: center; color: var(--text-light); font-size: 28rpx; }
