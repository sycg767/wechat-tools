@import "../../app.wxss";

.tabs {
  display: flex;
  white-space: nowrap;
  background: transparent;
  margin-bottom: 30rpx;
}

.tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 26rpx;
  margin-right: 14rpx;
  border-radius: var(--border-radius-pill);
  background: #FFFFFF;
  color: var(--text-second);
  font-size: 26rpx;
  box-shadow: var(--shadow-soft);
  flex-shrink: 0;
}

.tab.active {
  background: var(--text-main);
  color: #FFFFFF;
}

.content-section {
  margin-bottom: 30rpx;
}

.input-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.input-item {
  flex: 1;
  margin-bottom: 28rpx;
}

.label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.input,
.picker-value {
  width: 100%;
  min-height: 88rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  font-size: 30rpx;
  display: flex;
  align-items: center;
  color: var(--text-main);
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-main);
}

.checkbox-group {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.checkbox-item,
.option-toggle {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-second);
}

.option-toggle {
  margin-bottom: 28rpx;
}

.mode-switch {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.mode-item {
  flex: 1;
  text-align: center;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  color: var(--text-second);
  font-size: 26rpx;
}

.mode-item.active {
  background: #FFFFFF;
  color: var(--text-main);
  box-shadow: var(--shadow-soft);
}

.strength-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding: 20rpx 22rpx;
  background: var(--card-subtle);
  border-radius: var(--border-radius-lg);
}

.strength-badge {
  font-size: 24rpx;
  border-radius: var(--border-radius-pill);
  padding: 8rpx 20rpx;
  color: #FFFFFF;
}

.strength-weak { background: var(--error-color); }
.strength-medium { background: var(--warning-color); }
.strength-strong { background: var(--success-color); }

.result-section,
.history-section {
  margin-top: 0;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.copy-all {
  font-size: 24rpx;
  color: var(--text-main);
}

.result-list,
.history-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.result-item,
.history-item {
  padding: 22rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.result-text {
  flex: 1;
  margin-right: 20rpx;
  font-size: 30rpx;
  color: var(--text-main);
  font-family: monospace;
  word-break: break-all;
}

.copy-btn {
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--text-second);
}

.history-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.history-type {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
}

.history-time,
.history-params {
  font-size: 22rpx;
  color: var(--text-second);
}

.history-result {
  display: block;
  margin: 10rpx 0 16rpx;
  font-size: 26rpx;
  color: var(--text-main);
  word-break: break-all;
}

.history-actions {
  display: flex;
  gap: 20rpx;
}

.history-action {
  font-size: 24rpx;
  color: var(--text-main);
}
