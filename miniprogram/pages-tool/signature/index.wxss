@import "../../app.wxss";

.signature-page {
  display: flex;
  flex-direction: column;
}

.no-bar::before {
  display: none;
}

.preview-card,
.action-card {
  margin-bottom: 24rpx;
}

.preview-card {
  padding-bottom: 36rpx;
}

.signature-preview-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.signature-preview {
  width: 100%;
  height: 360rpx;
  border-radius: var(--border-radius-lg);
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F8FA 100%);
}

.preview-tip {
  margin-top: 20rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: var(--text-second);
  text-align: center;
}

.signature-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 12rpx 8rpx;
  text-align: center;
}

.empty-mark {
  width: 132rpx;
  height: 132rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, #1C1C1E 0%, #2E2E33 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 40rpx rgba(17, 24, 39, 0.16);
}

.empty-title {
  margin-top: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}

.btn-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.ghost-btn {
  background: var(--card-subtle);
}

.tips-block {
  margin-top: 4rpx;
}
