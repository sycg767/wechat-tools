@import "../../app.wxss";

.form-card {
  margin-bottom: 24rpx;
}

.card-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-row .btn,
.footer-actions .btn {
  flex: 1;
}

.file-chip {
  margin-top: 18rpx;
  display: inline-flex;
  max-width: 100%;
  padding: 12rpx 20rpx;
  border-radius: var(--border-radius-pill);
  background: rgba(17, 24, 39, 0.06);
  color: var(--text-main);
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

.signature-preview {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  text-align: center;
}

.signature-preview image {
  width: 260rpx;
  height: 132rpx;
}

.page-tabs {
  margin-bottom: 20rpx;
}

.tabs-scroll {
  white-space: nowrap;
}

.tab {
  display: inline-block;
  margin-right: 12rpx;
  padding: 14rpx 26rpx;
  border-radius: var(--border-radius-pill);
  background: var(--card-subtle);
  color: var(--text-second);
  font-size: 24rpx;
  font-weight: 600;
}

.tab-active {
  background: var(--text-main);
  color: #FFFFFF;
}

.size-box {
  margin-bottom: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
}

.size-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.size-row text {
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
}

.size-row slider {
  flex: 1;
}

.canvas-wrap {
  position: relative;
  overflow: hidden;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  border: 1px solid rgba(17, 24, 39, 0.06);
}

.page-thumb {
  width: 100%;
  display: block;
}

.placement {
  position: absolute;
  border: 2rpx dashed rgba(17, 24, 39, 0.45);
  background: rgba(17, 24, 39, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.placement-active {
  border-style: solid;
  border-color: var(--text-main);
  background: rgba(17, 24, 39, 0.12);
}

.placement-img {
  width: 100%;
  height: 100%;
}

.placement-x {
  position: absolute;
  top: -18rpx;
  right: -18rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: var(--error-color);
  color: #FFFFFF;
  font-size: 24rpx;
  line-height: 38rpx;
  text-align: center;
  z-index: 2;
}

.notice-box {
  margin-top: 22rpx;
}

.link-action {
  margin-top: 16rpx;
  padding: 0;
  background: transparent;
  color: var(--error-color);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.link-action::after {
  border: none;
}

.footer-actions {
  display: flex;
  gap: 20rpx;
}
