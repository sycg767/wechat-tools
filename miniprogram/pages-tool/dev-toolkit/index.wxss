@import "../../app.wxss";

.mode-card {
  padding: 20rpx;
  margin-bottom: 32rpx;
}

.tabs {
  white-space: nowrap;
}

.tab {
  display: inline-block;
  margin-right: 12rpx;
  padding: 14rpx 26rpx;
  border-radius: var(--border-radius-pill);
  background: var(--card-subtle);
  color: var(--text-second);
  font-size: 24rpx;
  font-weight: 600;
}

.tab-active {
  background: var(--text-main);
  color: #FFFFFF;
}

.tool-card {
  margin-bottom: 32rpx;
}

.card-sub {
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
}

.ta,
.single {
  width: 100%;
  box-sizing: border-box;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  border: 1px solid rgba(17, 24, 39, 0.06);
  color: var(--text-main);
}

.ta {
  min-height: 220rpx;
  padding: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
}

.single {
  height: 92rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.single.short {
  width: 220rpx;
  height: 72rpx;
  padding: 0 20rpx;
}

.btn-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.btn-mini {
  padding: 12rpx 22rpx;
  border-radius: var(--border-radius-pill);
  background: rgba(17, 24, 39, 0.06);
  color: var(--text-main);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
}

.btn-mini::after {
  border: none;
}

.btn-mini.primary {
  background: var(--text-main);
  color: #FFFFFF;
}

.seg {
  display: flex;
  gap: 12rpx;
  padding: 8rpx;
  margin-bottom: 18rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
}

.seg-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-second);
  border-radius: var(--border-radius-pill);
}

.seg-item.on {
  background: #FFFFFF;
  color: var(--text-main);
  box-shadow: var(--shadow-soft);
}

.result {
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
}

.result-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
}

.copy {
  color: var(--text-second);
  font-size: 22rpx;
  font-weight: 600;
}

.result-content {
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-main);
  word-break: break-all;
  white-space: pre-wrap;
}

.error {
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  border-radius: var(--border-radius-lg);
  background: var(--error-soft);
  color: var(--error-color);
  font-size: 24rpx;
  line-height: 1.6;
}

.kv {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin: 18rpx 0;
}

.k {
  width: 180rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--text-second);
}

.v {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-main);
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  word-break: break-all;
  line-height: 1.7;
}

.hash-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1px solid rgba(17, 24, 39, 0.06);
}

.hash-row:last-child {
  border-bottom: none;
}

.hash-label {
  width: 120rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--text-second);
}

.hash-val {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-main);
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  word-break: break-all;
  line-height: 1.7;
}

.row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.check {
  padding: 12rpx 22rpx;
  border-radius: var(--border-radius-pill);
  background: rgba(17, 24, 39, 0.06);
  color: var(--text-second);
  font-size: 24rpx;
  font-weight: 600;
}

.check.on {
  background: var(--text-main);
  color: #FFFFFF;
}

.uuid-list {
  margin-top: 20rpx;
}

.uuid-item {
  margin-bottom: 10rpx;
  padding: 18rpx 22rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  font-size: 24rpx;
  color: var(--text-main);
  word-break: break-all;
  line-height: 1.7;
}

.color-preview {
  width: 100%;
  height: 132rpx;
  margin: 18rpx 0;
  border-radius: var(--border-radius-lg);
  border: 1px solid rgba(17, 24, 39, 0.06);
}

.notice-box {
  margin-top: 24rpx;
}

.notice-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: var(--text-main);
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
}

.copy-inline {
  padding: 8rpx 20rpx;
  border-radius: var(--border-radius-pill);
  background: var(--card-subtle);
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-second);
  font-family: inherit;
}

.json-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.stat-pill {
  padding: 8rpx 22rpx;
  border-radius: var(--border-radius-pill);
  background: rgba(17, 24, 39, 0.06);
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-main);
}

.comp-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 18rpx 0;
}

.comp-swatch {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  border: 1px solid rgba(17, 24, 39, 0.08);
  flex-shrink: 0;
}

.tip {
  margin: 12rpx 0 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-second);
}
