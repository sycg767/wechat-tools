@import "../../app.wxss";

.group-selector {
  margin-bottom: 20rpx;
}

.group-scroll,
.type-scroll {
  white-space: nowrap;
  width: 100%;
}

.group-item,
.type-item {
  display: inline-block;
  margin-right: 16rpx;
  padding: 16rpx 28rpx;
  border-radius: var(--border-radius-pill);
  background: #FFFFFF;
  color: var(--text-second);
  font-size: 26rpx;
  box-shadow: var(--shadow-soft);
}

.group-item.active,
.type-item.active {
  background: var(--text-main);
  color: #FFFFFF;
}

.search-row {
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 92rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: var(--border-radius-lg);
  background: #FFFFFF;
  font-size: 28rpx;
  color: var(--text-main);
  box-shadow: var(--shadow-soft);
}

.search-placeholder {
  color: var(--text-placeholder);
}

.active-type-bar {
  margin-bottom: 16rpx;
}

.active-type-name {
  font-size: 24rpx;
  color: var(--text-second);
}

.type-selector {
  margin-bottom: 28rpx;
}

.convert-card {
  margin-bottom: 30rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1px solid rgba(17, 24, 39, 0.05);
  padding: 20rpx 0;
}

.input-row:last-child {
  border-bottom: none;
}

.unit-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-main);
}

.unit-result {
  flex: 1;
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-main);
  word-break: break-all;
}

.unit-picker {
  max-width: 320rpx;
  padding: 14rpx 20rpx;
  border-radius: var(--border-radius-md);
  background: var(--card-subtle);
  font-size: 26rpx;
  color: var(--text-second);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.swap-icon {
  text-align: center;
  color: var(--text-second);
  font-size: 40rpx;
  margin: 18rpx 0;
}

.quick-list {
  margin-bottom: 24rpx;
}

.list-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.list-item {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1px solid rgba(17, 24, 39, 0.05);
}

.list-item:last-child {
  border-bottom: none;
}

.item-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-second);
}

.item-value {
  font-size: 28rpx;
  font-weight: 600;
  text-align: right;
  color: var(--text-main);
}
