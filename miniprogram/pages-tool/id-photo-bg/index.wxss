@import "../../app.wxss";

.form-card {
  opacity: 0.55;
  pointer-events: none;
  transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.config-title {
  margin-bottom: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.color-list {
  display: flex;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.color-option {
  flex: 1;
  padding: 24rpx 16rpx;
  border-radius: var(--border-radius-lg);
  border: 1px solid rgba(17, 24, 39, 0.08);
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  transition: all 0.3s ease;
}

.color-option-active {
  border-color: rgba(17, 24, 39, 0.16);
  box-shadow: var(--shadow-soft);
  transform: translateY(-2rpx);
}

.color-preview {
  width: 84rpx;
  height: 104rpx;
  border-radius: 18rpx;
  border: 1px solid rgba(17, 24, 39, 0.05);
}

.preview-blue { background: #438EDB; }
.preview-white { background: #FFFFFF; }
.preview-red { background: #ED1941; }

.color-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-main);
}

.info-box {
  margin-bottom: 36rpx;
}

.info-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}
