@import "../../app.wxss";

.header-card {
  margin-bottom: 24rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.counter {
  font-size: 22rpx;
  color: var(--text-second);
}

.title-input,
.md-input {
  width: 100%;
  box-sizing: border-box;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  border: 1px solid rgba(17, 24, 39, 0.06);
  color: var(--text-main);
}

.title-input {
  height: 96rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.md-input {
  min-height: 640rpx;
  padding: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
}

.tool-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.mini-action {
  padding: 12rpx 22rpx;
  border-radius: var(--border-radius-pill);
  background: rgba(17, 24, 39, 0.06);
  color: var(--text-main);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
}

.mini-action::after {
  border: none;
}

.mini-action.danger {
  color: var(--error-color);
  background: var(--error-soft);
}

.notice-box {
  margin-top: 24rpx;
}

.footer-actions {
  display: flex;
  gap: 20rpx;
}

.footer-actions .btn {
  flex: 1;
}
