@import "../../app.wxss";

.kv {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin: 18rpx 0;
}

.k {
  width: 120rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--text-second);
}

.v {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-main);
  line-height: 1.7;
  word-break: break-all;
}

.password {
  font-family: 'SFMono-Regular', Consolas, monospace;
}

.btn-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-mini {
  padding: 12rpx 22rpx;
  border-radius: var(--border-radius-pill);
  background: rgba(17, 24, 39, 0.06);
  color: var(--text-main);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
}

.btn-mini::after {
  border: none;
}

.btn-mini.primary {
  background: var(--text-main);
  color: #FFFFFF;
}

.btn-mini.danger {
  background: var(--error-soft);
  color: var(--error-color);
}

.note-box {
  margin-top: 28rpx;
}

.note-text {
  margin-top: 14rpx;
  padding: 24rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-main);
  word-break: break-word;
}

.notice-box {
  margin-top: 24rpx;
}
