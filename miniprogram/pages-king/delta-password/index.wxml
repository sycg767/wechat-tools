<view class="container delta-page">
  <view class="scan-layer"></view>
  <view class="hero-panel">
    <view class="hero-kicker">
      <text class="signal-dot"></text>
      <text>DAILY TACTICAL INTEL</text>
    </view>
    <view class="hero-title">三角洲密码</view>
    <view class="hero-desc">每日地图门禁密码速查，进入行动前一眼确认。</view>
    <view class="hero-meta">
      <view class="meta-chip">今日密码</view>
      <view class="meta-chip">点击卡片复制</view>
      <view class="meta-chip meta-chip-warning" wx:if="{{stale}}">缓存数据</view>
    </view>
  </view>

  <view class="notice notice-warning tactical-notice" wx:if="{{stale}}">
    <view class="notice-title">当前展示缓存数据</view>
    <view class="notice-row">数据源暂时不可用，已优先展示最近一次成功获取的密码。</view>
  </view>

  <view class="notice notice-danger tactical-notice" wx:if="{{error}}">
    <view class="notice-title">获取失败</view>
    <view class="notice-row">{{error}}</view>
  </view>

  <view class="card loading-card" wx:if="{{loading && !items.length}}">
    <view class="loading-radar"></view>
    <view class="loading-copy">
      <view class="loading-title">正在同步今日情报</view>
      <view class="loading-desc">连接数据源，解析地图密码中。</view>
    </view>
  </view>

  <view class="password-grid" wx:if="{{items.length}}">
    <block wx:for="{{items}}" wx:for-index="index" wx:key="mapName">
      <view class="password-card {{index === 0 ? 'password-card-primary' : ''}}" bindtap="handleCopy" data-password="{{item.password}}" data-map-name="{{item.mapName}}" hover-class="password-card-active">
        <view class="card-topline">
          <text class="map-index">MAP 0{{index + 1}}</text>
          <text class="copy-pill">复制</text>
        </view>
        <view class="map-name">{{item.mapName}}</view>
        <view class="code-box">
          <text class="password-code">{{item.password}}</text>
        </view>
        <view class="update-row">
          <text>UPDATED</text>
          <text>{{item.updatedAt}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="card empty-card" wx:if="{{!loading && !items.length && !error}}">
    <view class="empty-title">暂无密码数据</view>
    <view class="empty-desc">请稍后刷新重试。</view>
  </view>

  <button class="refresh-command {{refreshing || loading ? 'refresh-command-disabled' : ''}}" bindtap="handleRefresh" hover-class="refresh-command-hover">
    <text class="refresh-mark">↻</text>
    <text>{{refreshing || loading ? '刷新中...' : '刷新今日密码'}}</text>
  </button>

  <view class="source-panel">
    <view class="source-label">数据来源</view>
    <view class="source-name">{{sourceName || '三角洲行动一图流'}}</view>
    <view class="source-time" wx:if="{{fetchedAt}}">获取时间：{{fetchedAt}}</view>
  </view>
</view>
