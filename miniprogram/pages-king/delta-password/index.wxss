@import "../../app.wxss";

.delta-page {
  position: relative;
  min-height: 100vh;
  padding-bottom: 56rpx;
  background: #07110F;
  overflow: hidden;
}

.delta-page::before {
  content: "";
  position: fixed;
  left: -160rpx;
  top: -180rpx;
  width: 640rpx;
  height: 640rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(37, 211, 102, 0.26) 0%, rgba(37, 211, 102, 0) 64%);
  pointer-events: none;
}

.delta-page::after {
  content: "";
  position: fixed;
  right: -220rpx;
  top: 260rpx;
  width: 620rpx;
  height: 620rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245, 158, 11, 0.22) 0%, rgba(245, 158, 11, 0) 66%);
  pointer-events: none;
}

.scan-layer {
  position: fixed;
  inset: 0;
  opacity: 0.1;
  pointer-events: none;
  background-image: linear-gradient(rgba(255, 255, 255, 0.28) 1rpx, transparent 1rpx), linear-gradient(90deg, rgba(255, 255, 255, 0.18) 1rpx, transparent 1rpx);
  background-size: 56rpx 56rpx;
}

.hero-panel,
.password-grid,
.tactical-notice,
.loading-card,
.empty-card,
.refresh-command,
.source-panel {
  position: relative;
  z-index: 1;
}

.hero-panel {
  margin: 8rpx 0 30rpx;
  padding: 42rpx 36rpx 36rpx;
  border-radius: 36rpx;
  color: #F8FAFC;
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.96) 0%, rgba(13, 54, 45, 0.94) 62%, rgba(64, 43, 18, 0.94) 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-shadow: 0 26rpx 70rpx rgba(0, 0, 0, 0.36);
  overflow: hidden;
}

.hero-panel::before {
  content: "";
  position: absolute;
  right: -90rpx;
  top: -120rpx;
  width: 340rpx;
  height: 340rpx;
  border: 2rpx solid rgba(34, 197, 94, 0.28);
  border-radius: 50%;
}

.hero-panel::after {
  content: "";
  position: absolute;
  right: 40rpx;
  bottom: 30rpx;
  width: 170rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #22C55E 0%, #F59E0B 100%);
  opacity: 0.85;
}

.hero-kicker {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  font-weight: 800;
  color: rgba(187, 247, 208, 0.9);
}

.signal-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #22C55E;
  box-shadow: 0 0 24rpx rgba(34, 197, 94, 0.9);
}

.hero-title {
  margin-top: 24rpx;
  font-size: 58rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.hero-desc {
  max-width: 520rpx;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(226, 232, 240, 0.78);
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 30rpx;
}

.meta-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #D1FAE5;
  background: rgba(34, 197, 94, 0.12);
  border: 1rpx solid rgba(134, 239, 172, 0.22);
}

.meta-chip-warning {
  color: #FEF3C7;
  background: rgba(245, 158, 11, 0.16);
  border-color: rgba(245, 158, 11, 0.26);
}

.tactical-notice {
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.2);
}

.password-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
}

.password-card {
  min-height: 254rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  color: #E5E7EB;
  background: linear-gradient(155deg, rgba(15, 23, 42, 0.94) 0%, rgba(17, 24, 39, 0.92) 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.26);
  overflow: hidden;
}

.password-card-primary {
  grid-column: span 2;
  min-height: 276rpx;
  background: linear-gradient(140deg, rgba(6, 78, 59, 0.98) 0%, rgba(15, 23, 42, 0.96) 58%, rgba(120, 53, 15, 0.9) 100%);
  border-color: rgba(34, 197, 94, 0.34);
}

.password-card-active {
  transform: scale(0.98);
  opacity: 0.86;
}

.card-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.map-index {
  font-size: 18rpx;
  letter-spacing: 2rpx;
  font-weight: 900;
  color: rgba(134, 239, 172, 0.84);
}

.copy-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.82);
  font-size: 20rpx;
  font-weight: 800;
}

.map-name {
  margin-top: 24rpx;
  font-size: 29rpx;
  font-weight: 900;
  color: #F8FAFC;
}

.password-card-primary .map-name {
  font-size: 34rpx;
}

.code-box {
  margin-top: 20rpx;
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(2, 6, 23, 0.38);
  border: 1rpx solid rgba(34, 197, 94, 0.16);
}

.password-code {
  display: block;
  font-size: 46rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: 8rpx;
  color: #BBF7D0;
  text-shadow: 0 0 24rpx rgba(34, 197, 94, 0.32);
}

.password-card-primary .password-code {
  font-size: 66rpx;
  letter-spacing: 12rpx;
}

.update-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  font-size: 19rpx;
  letter-spacing: 1rpx;
  font-weight: 800;
  color: rgba(203, 213, 225, 0.62);
}

.loading-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  color: #E5E7EB;
  background: rgba(15, 23, 42, 0.9);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.loading-radar {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  background: conic-gradient(from 90deg, rgba(34, 197, 94, 0), rgba(34, 197, 94, 0.9));
  box-shadow: inset 0 0 0 16rpx rgba(15, 23, 42, 0.9);
}

.loading-title {
  font-size: 28rpx;
  font-weight: 900;
}

.loading-desc,
.empty-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(203, 213, 225, 0.68);
}

.empty-card {
  padding: 44rpx 32rpx;
  text-align: center;
  color: #E5E7EB;
  background: rgba(15, 23, 42, 0.86);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 900;
}

.refresh-command {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 92rpx;
  margin-top: 32rpx;
  border: 0;
  border-radius: 28rpx;
  color: #052E16;
  font-size: 30rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #A7F3D0 0%, #22C55E 55%, #F59E0B 100%);
  box-shadow: 0 18rpx 44rpx rgba(34, 197, 94, 0.28);
}

.refresh-command::after {
  border: 0;
}

.refresh-command-hover {
  transform: scale(0.98);
  opacity: 0.88;
}

.refresh-command-disabled {
  opacity: 0.68;
}

.refresh-mark {
  font-size: 34rpx;
  line-height: 1;
}

.source-panel {
  margin-top: 28rpx;
  padding: 26rpx 28rpx;
  border-radius: 28rpx;
  color: rgba(226, 232, 240, 0.76);
  background: rgba(15, 23, 42, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
}

.source-label {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  font-weight: 900;
  color: rgba(134, 239, 172, 0.82);
}

.source-name {
  margin-top: 12rpx;
  font-size: 27rpx;
  font-weight: 900;
  color: #F8FAFC;
}

.source-time {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: rgba(203, 213, 225, 0.68);
}
