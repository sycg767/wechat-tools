@import "../../app.wxss";

.page {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 32rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 40rpx;
  padding: 8rpx 4rpx 0;
}

.header-content {
  flex-shrink: 0;
}

.header-title {
  font-size: 48rpx;
  line-height: 1.15;
  font-weight: 800;
  letter-spacing: -1.2rpx;
  color: var(--text-main);
}

.header-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-second);
}

.header-actions {
  flex: 1;
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  justify-content: flex-end;
  align-items: flex-start;
  padding-top: 4rpx;
  padding-right: 8rpx;
}

.action-group {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.action-group.main {
  gap: 12rpx;
}

.header-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.header-action.secondary {
  width: 80rpx;
}

.header-action.primary {
  width: 92rpx;
}

.action-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-soft);
  position: relative;
  overflow: hidden;
}

.header-action.secondary .action-icon-wrap {
  background: #FFFFFF;
  border: var(--border-premium);
  color: var(--text-main);
}

.header-action.primary .action-icon-wrap {
  background: var(--primary-color);
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(17, 24, 39, 0.15);
}

.ocr-btn .action-icon-wrap {
  background: linear-gradient(135deg, #111111 0%, #333333 100%);
}

.add-btn .action-icon-wrap {
  background: var(--primary-color);
}

.action-label {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-second);
  white-space: nowrap;
}

.header-action.primary .action-label {
  color: var(--text-main);
  font-weight: 700;
}

.icon-plus {
  font-size: 44rpx;
  font-weight: 300;
  line-height: 1;
}

.icon-font {
  font-size: 28rpx;
  font-weight: 700;
}

.icon-emoji {
  font-size: 32rpx;
}

.action-hover {
  opacity: 0.7;
  transform: scale(0.95);
}

.action-hover-main {
  transform: scale(0.92);
}

.action-hover-main .action-icon-wrap {
  box-shadow: 0 4rpx 10rpx rgba(17, 24, 39, 0.1);
}

.ocr-status-bar {
  margin-bottom: 28rpx;
  padding: 24rpx 28rpx;
  border-radius: var(--border-radius-lg);
  background: linear-gradient(180deg, #FFFFFF 0%, #FBFBFD 100%);
  border: var(--border-premium);
  box-shadow: var(--shadow-soft);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.ocr-status-bar.processing {
  background: var(--warning-soft);
}

.ocr-info {
  display: flex;
  flex-direction: column;
}

.ocr-text-main {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
}

.ocr-text-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-second);
}

.ocr-close {
  font-size: 38rpx;
  color: var(--text-second);
  padding: 10rpx;
}

.ocr-result-card {
  margin-bottom: 24rpx;
}

.ocr-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.copy-btn {
  background: rgba(17, 24, 39, 0.08);
  color: var(--text-main);
  border-radius: var(--border-radius-pill);
  font-size: 22rpx;
  font-weight: 600;
  padding: 0 22rpx;
  line-height: 1.9;
}

.ocr-raw-box {
  margin-top: 18rpx;
  padding: 22rpx;
  max-height: 360rpx;
  overflow: auto;
  background: var(--card-subtle);
  border-radius: var(--border-radius-lg);
}

.ocr-raw-text {
  font-size: 24rpx;
  line-height: 1.68;
  color: var(--text-main);
  white-space: pre-wrap;
  word-break: break-all;
}

.player-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.player-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #FBFBFD 100%);
  border-radius: var(--border-radius-apple);
  border: var(--border-premium);
  box-shadow: var(--shadow-premium);
  transition: all 0.3s ease;
}

.card-hover {
  background: rgba(17, 24, 39, 0.02);
}

.card-click-area {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.player-actions {
  position: relative;
  z-index: 2;
}

.player-card.warning {
  background: linear-gradient(180deg, #FFF7F5 0%, #FFFFFF 100%);
  border: 1px solid rgba(180, 35, 24, 0.12);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding-right: 56rpx;
}

.player-name-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.player-name-row {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
}

.player-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.player-name {
  max-width: 100%;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--text-main);
  word-break: break-all;
}

.player-alias {
  font-size: 20rpx;
  line-height: 1.45;
  color: var(--text-second);
  word-break: break-all;
}

.player-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 84rpx;
  min-height: 52rpx;
  padding: 10rpx 18rpx;
  border-radius: var(--border-radius-pill);
  background: rgba(17, 24, 39, 0.06);
  color: var(--text-main);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
  box-sizing: border-box;
}

.deduction-badge {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: var(--border-radius-pill);
  background: var(--error-color);
  color: #FFFFFF;
  font-size: 20rpx;
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.3s ease;
}

.deduction-badge.show {
  opacity: 1;
  transform: translateY(0);
}

.score-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin: 26rpx 0 30rpx;
}

.score-value {
  font-size: 68rpx;
  line-height: 1;
  font-weight: 800;
  color: var(--text-main);
  font-family: 'DIN Alternate', 'Arial Narrow', sans-serif;
}

.player-card.warning .score-value {
  color: var(--error-color);
}

.score-unit {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: var(--text-second);
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid rgba(17, 24, 39, 0.05);
  padding-top: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  margin-bottom: 4rpx;
  font-size: 20rpx;
  color: var(--text-second);
}

.stat-value {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(17, 24, 39, 0.06);
}

.ocr-hit,
.ocr-miss {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(17, 24, 39, 0.08);
}

.ocr-hit-title {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-main);
}

.ocr-hit-line,
.ocr-miss {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--text-second);
  word-break: break-all;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.03); }
  100% { transform: scale(1); }
}

.pulse {
  animation: pulse 0.4s ease-out;
}

.card {
  background: linear-gradient(180deg, #FFFFFF 0%, #FBFBFD 100%);
  border-radius: var(--border-radius-apple);
  padding: 32rpx;
  margin-top: 24rpx;
  border: var(--border-premium);
  box-shadow: var(--shadow-premium);
}

.card-title,
.calendar-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.btn {
  height: 88rpx;
  line-height: 1;
  padding: 0;
  margin: 0;
  width: 100% !important;
  border-radius: 24rpx;
}

.result-btn.good {
  background: var(--success-color);
}

.result-btn.bad {
  background: var(--error-color);
}

.result-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
}

.quick-tip {
  margin-top: 12rpx;
}

.flex {
  flex: 1;
}

.summary {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: var(--text-second);
}

.calendar-card {
  padding: 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.calendar-nav {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-btn {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: var(--text-main);
}

.current-month {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 20rpx;
}

.calendar-weekdays text {
  font-size: 22rpx;
  color: var(--text-second);
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.calendar-day {
  height: 80rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 18rpx;
  position: relative;
}

.calendar-day.today {
  background: rgba(17, 24, 39, 0.06);
}

.calendar-day.selected {
  border: 2rpx solid var(--text-main);
}

.day-num {
  font-size: 26rpx;
  color: var(--text-main);
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-top: 4rpx;
}

.calendar-day.good .day-dot {
  background: var(--success-color);
}

.calendar-day.bad .day-dot {
  background: var(--error-color);
}

.calendar-tip {
  margin-top: 20rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-second);
}

.history-detail {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(17, 24, 39, 0.05);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.detail-date {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.detail-summary {
  margin-bottom: 24rpx;
  font-size: 22rpx;
  color: var(--text-second);
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-item {
  padding: 20rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
}

.detail-item-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.detail-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
}

.detail-score {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
}

.detail-item-sub {
  font-size: 22rpx;
  color: var(--text-second);
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: var(--border-radius-pill);
  font-size: 22rpx;
}

.tag.good {
  color: var(--success-color);
  background: var(--success-soft);
}

.tag.bad {
  color: var(--error-color);
  background: var(--error-soft);
}

.empty-state {
  grid-column: span 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: var(--text-second);
  font-size: 28rpx;
}

.modal {
  position: fixed;
  inset: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.28);
  backdrop-filter: blur(6px);
}

.modal-container {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 40rpx;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  transform: translateY(100%);
  transition: all 0.3s ease;
}

.modal.show .modal-container {
  transform: translateY(0);
}

.modal-header {
  margin-bottom: 32rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
}

.modal-input {
  background: var(--card-subtle);
  border-radius: var(--border-radius-lg);
  padding: 0 24rpx;
  height: 104rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  color: var(--text-main);
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.modal-btn {
  flex: 1;
  height: 92rpx;
  border-radius: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
}

.modal-btn.cancel {
  background: var(--card-subtle);
  color: var(--text-main);
}

.modal-btn.confirm {
  background: var(--primary-color);
  color: #FFFFFF;
}

.mode-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: var(--card-subtle);
}

.mode-item {
  flex: 1;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-second);
}

.mode-item.active {
  background: #FFFFFF;
  color: var(--text-main);
  box-shadow: 0 8rpx 18rpx rgba(17, 24, 39, 0.08);
}

.settings-mode-selector {
  margin-bottom: 20rpx;
}

.settings-tip {
  margin-bottom: 20rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-second);
}

.settings-subtip {
  margin-top: -4rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-second);
}
