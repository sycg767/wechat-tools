@import "../../app.wxss";

.form-card {
  opacity: 0.55;
  pointer-events: none;
  transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.form-item {
  margin-bottom: 36rpx;
}

.label {
  margin-bottom: 20rpx;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.name-input {
  width: 100%;
  height: 112rpx;
  padding: 0 84rpx 0 36rpx;
  box-sizing: border-box;
  border-radius: var(--border-radius-lg);
  background: #FFFFFF;
  border: 1px solid rgba(17, 24, 39, 0.06);
  color: var(--text-main);
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.name-input:focus {
  border-color: rgba(17, 24, 39, 0.14);
  box-shadow: var(--shadow-soft);
  transform: translateY(-2rpx);
}

.input-placeholder {
  color: var(--text-placeholder);
}

.input-clear {
  position: absolute;
  right: 24rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.14);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  z-index: 2;
}
