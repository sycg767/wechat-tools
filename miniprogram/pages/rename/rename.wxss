@import "../../app.wxss";

.page-header {
  margin-bottom: 64rpx;
  padding: 20rpx 8rpx;
}

.page-title {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: -2rpx;
  margin-bottom: 16rpx;
}

.page-desc {
  font-size: 28rpx;
  color: var(--text-second);
  line-height: 1.6;
}

.form-card {
  opacity: 0.5;
  pointer-events: none;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  background: #F9FAFB;
  border-radius: 48rpx;
  padding: 48rpx;
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 24rpx;
  display: block;
  letter-spacing: 1rpx;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.name-input {
  width: 100%;
  height: 120rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 0 80rpx 0 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  box-sizing: border-box;
  border: 1px solid rgba(0, 0, 0, 0.05);
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
}

.name-input:focus {
  background: #ffffff;
  border-color: var(--text-main);
  box-shadow: var(--shadow-premium);
  transform: translateY(-2rpx);
}

.input-placeholder {
  color: var(--text-placeholder);
}

.input-clear {
  position: absolute;
  right: 24rpx;
  width: 40rpx;
  height: 40rpx;
  background: #C7C7CC;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  z-index: 2;
}
