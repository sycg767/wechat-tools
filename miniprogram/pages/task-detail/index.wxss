@import "../../app.wxss";

.detail-card,
.result-action-card,
.fail-card {
  margin-top: 24rpx;
}

.detail-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 20rpx;
  word-break: break-all;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 22rpx;
  color: var(--text-second);
}

.detail-value {
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--text-main);
}

.processing-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}

.result-action-title,
.fail-title {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.result-action-desc,
.fail-desc {
  margin-bottom: 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}

.action-btn + .action-btn {
  margin-top: 16rpx;
}
