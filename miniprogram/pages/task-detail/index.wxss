@import "../../app.wxss";

.detail-card,
.result-action-card,
.fail-card {
  margin-top: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(17, 24, 39, 0.04);
  word-break: break-all;
}

.detail-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.detail-row:first-child {
  padding-top: 0;
}

.detail-label {
  font-size: 26rpx;
  color: var(--text-second);
  flex-shrink: 0;
  margin-right: 32rpx;
}

.detail-value {
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--text-main);
  text-align: right;
  font-weight: 500;
}

.processing-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}

.result-action-title,
.fail-title {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.result-action-desc,
.fail-desc {
  margin-bottom: 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}

.action-btn + .action-btn {
  margin-top: 16rpx;
}

.batch-save-bar {
  margin-bottom: 32rpx;
}

.btn-dark {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--border-radius-lg);
  background: #1C1C1E;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.btn-dark-hover {
  opacity: 0.8;
}

.btn-dark[disabled] {
  opacity: 0.5;
}

.image-gallery {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}

.gallery-item {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F5F5F5;
  position: relative;
  box-sizing: border-box;
}

.gallery-img {
  width: 100%;
  height: 240rpx;
  display: block;
}

.gallery-name {
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  color: var(--text-main);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.gallery-save-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #FFFFFF;
  font-size: 22rpx;
  line-height: 1.5;
}
