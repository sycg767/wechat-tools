<view class="container">
  <view class="section-title">任务详情</view>

  <view wx:if="{{task}}" class="card detail-card">
    <view class="detail-row">工具：{{task.toolType || '未知工具'}}</view>
    <view class="detail-row">原文件：{{task.sourceFileName || '未命名文件'}}</view>
    <view class="detail-row">状态：{{task.status}}</view>
    <view wx:if="{{task.resultFileName}}" class="detail-row">结果文件：{{task.resultFileName}}</view>
    <view wx:if="{{task.message}}" class="detail-row">说明：{{task.message}}</view>
    <view wx:if="{{task.selectedStrategy}}" class="detail-row">策略：{{task.selectedStrategy}}</view>
    <view wx:if="{{task.strategyTraceText}}" class="detail-row">链路：{{task.strategyTraceText}}</view>
    <view wx:if="{{task.fallbackReason}}" class="detail-row">回退：{{task.fallbackReason}}</view>
    <view wx:if="{{task.qualityGateText}}" class="detail-row">门控：{{task.qualityGateText}}</view>
  </view>

  <progress-bar wx:if="{{task && task.status === 'PROCESSING'}}" text="处理中，请稍候..." percent="{{task.progress}}" />
  <view wx:if="{{task && task.status === 'PROCESSING' && task.toolType === 'word-pdf'}}" class="detail-row">说明：文件正在云端转换，请稍候。</view>

  <view wx:if="{{task && task.status === 'SUCCESS'}}" class="card result-action-card">
    <view class="result-action-title">处理完成</view>

    <view wx:if="{{task.isImage}}" class="result-action-desc">你可以先预览压缩图，再点击“保存到相册”落地到手机。</view>
    <view wx:elif="{{task.canOpen}}" class="result-action-desc">点击打开文件，然后在文档界面中自行转发。</view>
    <view wx:else class="result-action-desc">当前结果文件类型暂不支持在小程序内直接打开。</view>

    <button wx:if="{{task.canOpen}}" class="primary-btn" bindtap="handleOpenFile">
      {{task.isImage ? '预览图片' : '打开文件'}}
    </button>
    <button wx:if="{{task.isImage}}" class="primary-btn" bindtap="handleSaveImage">保存到相册</button>
    <button wx:if="{{!task.isImage}}" class="primary-btn" bindtap="handleShareFile">发送给好友</button>
  </view>

  <view wx:if="{{task && task.status === 'FAIL'}}" class="card fail-card">
    <view class="fail-title">处理失败</view>
    <view class="fail-desc">{{task.message || '请重新提交任务'}}</view>
  </view>

  <view wx:if="{{!loading && !task}}" class="card fail-card">
    <view class="fail-title">任务不存在</view>
    <view class="fail-desc">任务状态已失效，请重新提交。</view>
  </view>
</view>
