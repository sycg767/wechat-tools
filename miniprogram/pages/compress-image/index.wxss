@import "../../app.wxss";

.form-card {
  opacity: 0.55;
  pointer-events: none;
  transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.form-item {
  margin-bottom: 36rpx;
}

.form-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.quality-pill {
  padding: 10rpx 20rpx;
  border-radius: var(--border-radius-pill);
  background: rgba(17, 24, 39, 0.06);
  color: var(--text-main);
  font-size: 22rpx;
  font-weight: 700;
}

.quality-slider {
  margin: 0 4rpx;
}

.field-help {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}

.estimate-box {
  margin-bottom: 36rpx;
}

.tips-block {
  margin-top: 8rpx;
}
