@import "../../app.wxss";

.wheel-card {
  padding: 24rpx;
}

.wheel-canvas {
  width: 640rpx;
  height: 640rpx;
  display: block;
  margin: 0 auto;
}

.result-text {
  font-size: 34rpx;
  text-align: center;
}

.highlight {
  color: var(--error-color);
  font-size: 42rpx;
  font-weight: 800;
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: var(--border-radius-pill);
  background: var(--card-subtle);
  font-size: 26rpx;
}

.delete-btn {
  color: var(--error-color);
  font-size: 30rpx;
  line-height: 1;
}

.add-option {
  display: flex;
  gap: 16rpx;
}

.input {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  border: 1px solid rgba(17, 24, 39, 0.08);
  background: var(--card-subtle);
  padding: 0 18rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.add-btn {
  width: 180rpx;
}

.boss-card {
  line-height: 1.8;
}

.boss-title {
  font-size: 36rpx;
  font-weight: 800;
  margin-bottom: 22rpx;
}

.boss-row {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  color: var(--text-main);
}

.boss-text {
  color: var(--text-second);
}

.boss-tip {
  margin-top: 30rpx;
  font-size: 24rpx;
  color: var(--text-second);
}
