@import "../../app.wxss";

.eat-page {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.wheel-card {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.wheel-container {
  position: relative;
  width: 600rpx;
  height: 600rpx;
}

.wheel-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.result-section {
  margin-bottom: 32rpx;
  text-align: center;
}

.result-text {
  font-size: 34rpx;
  color: var(--text-main);
}

.highlight {
  color: var(--error-color);
  font-weight: 800;
  font-size: 42rpx;
}

.options-section {
  margin-bottom: 24rpx;
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-bottom: 30rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 12rpx 22rpx;
  border-radius: var(--border-radius-pill);
  background: var(--card-subtle);
  font-size: 26rpx;
  color: var(--text-main);
}

.delete-btn {
  margin-left: 10rpx;
  color: var(--error-color);
  font-weight: 700;
  padding: 0 10rpx;
}

.add-option {
  display: flex;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.input {
  flex: 1;
  height: 92rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  border: 1px solid rgba(17, 24, 39, 0.06);
  font-size: 28rpx;
  color: var(--text-main);
}

.add-btn {
  width: 180rpx;
  flex-shrink: 0;
}
