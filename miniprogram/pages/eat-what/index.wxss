.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.wheel-container {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  margin-bottom: 60rpx;
}

.wheel-canvas {
  width: 100%;
  height: 100%;
  display: block;
}


.result-section {
  margin-bottom: 40rpx;
  padding: 20rpx 40rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.result-text {
  font-size: 36rpx;
  color: #333;
}

.highlight {
  color: #ff4d4f;
  font-weight: bold;
  font-size: 44rpx;
}

.options-section {
  width: 100%;
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.option-item {
  background-color: #f0f2f5;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
}

.delete-btn {
  margin-left: 10rpx;
  color: #ff4d4f;
  font-weight: bold;
  padding: 0 10rpx;
}

.add-option {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.add-btn {
  width: 160rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 28rpx;
  padding: 0;
}

.reset-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #fff;
  color: #999;
  font-size: 28rpx;
  border: 2rpx solid #eee;
}