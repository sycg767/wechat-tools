@import "../../app.wxss";

.page-header {
  margin-bottom: 40rpx;
  padding-left: 8rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 26rpx;
  color: var(--text-second);
}

.form-card {
  opacity: 0.5;
  pointer-events: none;
  transition: all 0.3s ease;
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.info-box {
  background: #F2F2F7;
  border-radius: var(--border-radius-md);
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.info-icon {
  width: 32rpx;
  height: 32rpx;
  background: var(--text-second);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 24rpx;
  color: var(--text-second);
  line-height: 1.6;
}
