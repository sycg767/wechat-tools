@import "../../app.wxss";

.form-card {
  opacity: 0.55;
  pointer-events: none;
  transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.info-box {
  margin-bottom: 36rpx;
}

.info-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}
