<view class="container">
  <view class="header">
    <view class="title">单位转换</view>
    <view class="subtitle">先选统合大类，再选具体单位类型进行转换</view>
  </view>

  <view class="group-selector">
    <scroll-view scroll-x class="group-scroll">
      <view
        wx:for="{{groups}}"
        wx:key="id"
        class="group-item {{activeGroup === item.id ? 'active' : ''}}"
        bindtap="switchGroup"
        data-id="{{item.id}}"
      >{{item.name}}</view>
    </scroll-view>
  </view>

  <view class="search-row">
    <input
      class="search-input"
      value="{{searchKeyword}}"
      bindinput="onSearchTypeInput"
      placeholder="搜索单位类型（如 压力、油耗、网速）"
      placeholder-class="search-placeholder"
    />
  </view>

  <view class="active-type-bar" wx:if="{{activeTypeName}}">
    <text class="active-type-name">当前类型：{{activeTypeName}}</text>
  </view>

  <view class="type-selector" wx:if="{{types.length}}">
    <scroll-view scroll-x class="type-scroll">
      <view
        wx:for="{{types}}"
        wx:key="id"
        class="type-item {{activeType === item.id ? 'active' : ''}}"
        bindtap="switchType"
        data-id="{{item.id}}"
      >{{item.name}}</view>
    </scroll-view>
  </view>

  <view class="empty-state" wx:else>
    当前大类下暂无匹配类型，请更换关键词或切换统合大类。
  </view>

  <view class="convert-card" wx:if="{{activeType && currentUnits.length}}">
    <view class="input-row">
      <input
        class="unit-input"
        type="digit"
        value="{{inputValue}}"
        bindinput="onInput"
        placeholder="输入数值"
      />
      <picker bindchange="onFromUnitChange" value="{{fromUnitIndex}}" range="{{currentUnits}}" range-key="name">
        <view class="unit-picker">{{currentUnits[fromUnitIndex].name}} ▾</view>
      </picker>
    </view>

    <view class="swap-icon">⇅</view>

    <view class="input-row">
      <view class="unit-result">{{outputValue}}</view>
      <picker bindchange="onToUnitChange" value="{{toUnitIndex}}" range="{{currentUnits}}" range-key="name">
        <view class="unit-picker">{{currentUnits[toUnitIndex].name}} ▾</view>
      </picker>
    </view>
  </view>

  <view class="quick-list" wx:if="{{activeType && currentUnits.length}}">
    <view class="list-title">常用转换结果</view>
    <view class="list-item" wx:for="{{quickResults}}" wx:key="name">
      <text class="item-name">{{item.name}}</text>
      <text class="item-value">{{item.value}} {{item.unit}}</text>
    </view>
  </view>
</view>
