.container {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  margin-top: 10rpx;
}

.type-selector {
  margin-bottom: 30rpx;
}

.type-scroll {
  white-space: nowrap;
  width: 100%;
}

.type-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #fff;
  border-radius: 30rpx;
  margin-right: 20rpx;
}

.type-item.active {
  background: #07c160;
  color: #fff;
}

.convert-card {
  background: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 40rpx;
}

.input-row {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #eee;
  padding: 20rpx 0;
}

.unit-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.unit-result {
  flex: 1;
  font-size: 48rpx;
  font-weight: bold;
  color: #07c160;
}

.unit-picker {
  font-size: 28rpx;
  color: #666;
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.swap-icon {
  text-align: center;
  color: #ccc;
  font-size: 40rpx;
  margin: 20rpx 0;
}

.quick-list {
  background: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.list-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.item-name {
  font-size: 28rpx;
  color: #666;
}

.item-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}