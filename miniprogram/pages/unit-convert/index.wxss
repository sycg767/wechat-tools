.container {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  margin-top: 10rpx;
}

.group-selector {
  margin-bottom: 20rpx;
}

.group-scroll {
  white-space: nowrap;
  width: 100%;
}

.group-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #eef2f7;
  border-radius: 28rpx;
  margin-right: 16rpx;
}

.group-item.active {
  background: #3f7cff;
  color: #fff;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  border-radius: 16rpx;
  padding: 0 24rpx;
  background: #fff;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #bbb;
}

.active-type-bar {
  margin-bottom: 16rpx;
}

.active-type-name {
  font-size: 24rpx;
  color: #6b7280;
}

.type-selector {
  margin-bottom: 28rpx;
}

.type-scroll {
  white-space: nowrap;
  width: 100%;
}

.type-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #fff;
  border-radius: 30rpx;
  margin-right: 20rpx;
}

.type-item.active {
  background: #07c160;
  color: #fff;
}

.empty-state {
  background: #fff;
  color: #999;
  font-size: 26rpx;
  padding: 36rpx 28rpx;
  border-radius: 18rpx;
  margin-bottom: 24rpx;
}

.convert-card {
  background: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

.input-row {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #eee;
  padding: 20rpx 0;
}

.unit-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.unit-result {
  flex: 1;
  font-size: 48rpx;
  font-weight: bold;
  color: #07c160;
  word-break: break-all;
}

.unit-picker {
  max-width: 300rpx;
  font-size: 28rpx;
  color: #666;
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.swap-icon {
  text-align: center;
  color: #ccc;
  font-size: 40rpx;
  margin: 20rpx 0;
}

.quick-list {
  background: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.list-item {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.item-name {
  flex: 1;
  font-size: 26rpx;
  color: #666;
}

.item-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
}
