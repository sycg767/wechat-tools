.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.chart-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.header-card,
.chart-card {
  margin-bottom: 24rpx;
}

.title,
.chart-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.chart-title {
  font-size: 30rpx;
}

.chart-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8c8c8c;
}

.summary-row {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.summary-row-3 {
  grid-template-columns: repeat(3, 1fr);
}

.summary-item {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  text-align: center;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1677ff;
}

.summary-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8c8c8c;
}

.chart-scroll {
  height: 920rpx;
  margin-top: 20rpx;
}

.chart-canvas {
  width: 100%;
  display: block;
  border-radius: 16rpx;
  background: #fff;
}

.empty {
  color: #999;
  text-align: center;
  padding: 120rpx 0;
  font-size: 28rpx;
}
