@import "../../app.wxss";

.page {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 32rpx;
  box-sizing: border-box;
}

.header-card,
.chart-card {
  margin-bottom: 28rpx;
  padding: 32rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #FBFBFD 100%);
  border-radius: var(--border-radius-apple);
  border: var(--border-premium);
  box-shadow: var(--shadow-premium);
}

.title,
.chart-title {
  color: var(--text-main);
  font-weight: 800;
  line-height: 1.25;
}

.title {
  font-size: 42rpx;
}

.chart-title {
  font-size: 32rpx;
}

.chart-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-second);
}

.summary-row {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.summary-row-3 {
  grid-template-columns: repeat(3, 1fr);
}

.summary-item {
  padding: 20rpx 16rpx;
  text-align: center;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  border: 1px solid rgba(17, 24, 39, 0.03);
}

.summary-value {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-main);
}

.summary-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-second);
}

.chart-scroll {
  height: 920rpx;
  margin-top: 24rpx;
}

.chart-canvas {
  width: 100%;
  display: block;
  border-radius: var(--border-radius-lg);
  background: #FFFFFF;
}

.empty {
  padding: 140rpx 24rpx;
  text-align: center;
  color: var(--text-second);
  font-size: 28rpx;
}
