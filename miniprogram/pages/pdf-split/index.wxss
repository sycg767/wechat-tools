@import "../../app.wxss";

.page-header {
  margin-bottom: 40rpx;
  padding-left: 8rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 26rpx;
  color: var(--text-second);
}

.form-card {
  opacity: 0.5;
  pointer-events: none;
  transition: all 0.3s ease;
  padding: 32rpx;
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.input {
  background: #F2F2F7;
  height: 88rpx;
  border-radius: var(--border-radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
}

.tip {
  font-size: 22rpx;
  color: var(--text-second);
  margin-top: 12rpx;
}