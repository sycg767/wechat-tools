.container {
  padding: 30rpx;
  padding-bottom: 180rpx;
}

.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #888;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}


.form-card {
  opacity: 0.5;
  pointer-events: none;
  transition: all 0.3s;
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.preview-container {
  margin-bottom: 30rpx;
}

.preview-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.preview-box {
  position: relative;
  width: 100%;
  background: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 600rpx;
}

.watermark-marker {
  position: absolute;
  pointer-events: none;
  border: 2rpx dashed #07c160;
  background: rgba(7, 193, 96, 0.1);
  padding: 4rpx 8rpx;
  font-size: 20rpx;
  color: #07c160;
  white-space: nowrap;
  z-index: 100;
}

.tile-preview-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  pointer-events: none;
  z-index: 90;
}

.tile-item {
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  white-space: nowrap;
}

.marker-img {
  width: 60rpx;
  height: 60rpx;
}

.preview-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  text-align: center;
}

.radio-group {
  display: flex;
  gap: 30rpx;
}

.radio-label {
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
}

.image-uploader {
  width: 160rpx;
  height: 160rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}

.upload-placeholder {
  font-size: 60rpx;
  color: #ccc;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  background: #f7f8fa;
  height: 88rpx;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.color-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.color-item {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.color-item.active {
  border-color: #07c160;
  transform: scale(1.1);
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  transform: translateY(100%);
  transition: all 0.3s;
}

.bar-active {
  transform: translateY(0);
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

.btn-primary {
  background: #07c160;
  color: #fff;
}

.btn-disabled {
  background: #ccc;
  color: #fff;
}

.btn-hover {
  opacity: 0.8;
}