@import "../../app.wxss";

.container {
  padding-bottom: 180rpx;
}

.upload-card {
  margin-bottom: 32rpx;
}

.form-card {
  opacity: 0.55;
  pointer-events: none;
  transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.preview-container {
  margin-bottom: 36rpx;
}

.preview-title {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 700;
}

.preview-box {
  position: relative;
  width: 100%;
  border-radius: var(--border-radius-lg);
  overflow: hidden;
  background: var(--card-subtle);
  display: flex;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 600rpx;
}

.watermark-marker {
  position: absolute;
  pointer-events: none;
  padding: 4rpx 8rpx;
  font-size: 20rpx;
  color: var(--text-main);
  white-space: nowrap;
  z-index: 100;
}

.tile-preview-container {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
  pointer-events: none;
  z-index: 90;
}

.tile-item {
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  white-space: nowrap;
}

.marker-img {
  width: 60rpx;
  height: 60rpx;
}

.preview-tip {
  margin-top: 12rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-second);
}

.radio-group {
  display: flex;
  gap: 30rpx;
  flex-wrap: wrap;
}

.radio-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-main);
}

.image-uploader {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  border: 1px dashed rgba(17, 24, 39, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-placeholder {
  font-size: 60rpx;
  color: var(--text-placeholder);
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.input {
  background: #FFFFFF;
  height: 96rpx;
  border-radius: var(--border-radius-lg);
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1px solid rgba(17, 24, 39, 0.06);
}

.tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-second);
}

.color-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.color-item {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.color-item.active {
  border-color: var(--text-main);
  transform: scale(1.08);
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  box-shadow: 0 -8rpx 30rpx rgba(15, 23, 42, 0.06);
  transform: translateY(100%);
  transition: all 0.3s ease;
}

.bar-active {
  transform: translateY(0);
}
