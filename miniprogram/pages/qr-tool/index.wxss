@import "../../app.wxss";

.mode-card {
  padding: 20rpx;
  margin-bottom: 32rpx;
}

.tabs {
  display: flex;
  gap: 12rpx;
  padding: 8rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
}

.tab {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-second);
}

.tab.active {
  background: #FFFFFF;
  color: var(--text-main);
  box-shadow: var(--shadow-soft);
}

.content-card {
  margin-bottom: 32rpx;
}

.input-group {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 24rpx 26rpx;
  box-sizing: border-box;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--text-main);
}

.hint {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}

.upload-shell {
  min-height: 320rpx;
  border-radius: var(--border-radius-apple);
  background: linear-gradient(180deg, #FFFFFF 0%, #F8F9FB 100%);
  border: 1px dashed rgba(17, 24, 39, 0.14);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.06);
  position: relative;
}

.upload-icon::before,
.upload-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  background: var(--text-second);
  transform: translate(-50%, -50%);
}

.upload-icon::before { width: 40rpx; height: 4rpx; }
.upload-icon::after { width: 4rpx; height: 40rpx; }

.upload-text {
  font-size: 26rpx;
  color: var(--text-second);
}

.preview-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-img {
  width: 100%;
  height: 420rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
}

.re-upload {
  margin-top: 18rpx;
  padding: 8rpx 18rpx;
  border-radius: var(--border-radius-pill);
  background: rgba(17, 24, 39, 0.06);
  color: var(--text-main);
  font-size: 22rpx;
  font-weight: 600;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.btn-group .btn {
  flex: 1;
}

.progress-section {
  margin-bottom: 32rpx;
}

.result-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-title {
  width: 100%;
  margin-bottom: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.result-qr {
  width: 420rpx;
  height: 420rpx;
  margin-bottom: 20rpx;
}

.tip {
  font-size: 24rpx;
  color: var(--text-second);
}

.decoded-box {
  width: 100%;
  margin-bottom: 28rpx;
  padding: 24rpx 26rpx;
  box-sizing: border-box;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
}

.decoded-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--text-second);
}

.decoded-content {
  font-size: 30rpx;
  line-height: 1.65;
  color: var(--text-main);
  word-break: break-all;
}
