.container {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  margin-top: 10rpx;
}

.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  background: #07c160;
  color: #fff;
  font-weight: bold;
}

.content-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.textarea {
  width: 100%;
  height: 200rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.hint {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

.upload-area {
  height: 300rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  width: 80rpx;
  height: 80rpx;
  background: #eee;
  border-radius: 50%;
  margin-bottom: 20rpx;
  position: relative;
}

.upload-icon::before, .upload-icon::after {
  content: '';
  position: absolute;
  background: #999;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.upload-icon::before {
  width: 40rpx;
  height: 4rpx;
}

.upload-icon::after {
  width: 4rpx;
  height: 40rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #999;
}

.preview-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-img {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
}

.re-upload {
  font-size: 26rpx;
  color: #576b95;
  margin-top: 20rpx;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.primary-btn {
  flex: 1;
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
}

.scan-btn {
  flex: 1;
  background: #576b95;
  color: #fff;
  border-radius: 44rpx;
}

.primary-btn[disabled], .scan-btn[disabled] {
  background: #a5e5c5 !important;
  color: #fff !important;
}

.progress-section {
  margin-top: 40rpx;
}

.result-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  align-self: flex-start;
}

.result-qr {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 20rpx;
}

.tip {
  font-size: 24rpx;
  color: #999;
}

.decoded-box {
  width: 100%;
  background: #f0f0f0;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}

.decoded-label {
  font-size: 26rpx;
  color: #888;
  display: block;
  margin-bottom: 10rpx;
}

.decoded-content {
  font-size: 30rpx;
  color: #333;
  word-break: break-all;
}

.secondary-btn {
  width: 100%;
  background: #f2f2f2;
  color: #333;
  border-radius: 44rpx;
}
