.container {
  padding: 30rpx;
  background-color: #f0f0f0;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.canvas-area {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  overflow: hidden;
  margin-bottom: 30rpx;
}

.signature-canvas {
  width: 100%;
  height: 100%;
}

.controls {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.color-picker {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.color-item {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin: 0 20rpx;
  border: 4rpx solid transparent;
}

.color-item.active {
  border-color: #07c160;
  transform: scale(1.1);
}

.btn-group {
  display: flex;
  gap: 20rpx;
}

.clear-btn {
  flex: 1;
  background: #f2f2f2;
  color: #666;
  font-size: 28rpx;
  border-radius: 44rpx;
}

.save-btn {
  flex: 2;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 44rpx;
}

.tips {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}