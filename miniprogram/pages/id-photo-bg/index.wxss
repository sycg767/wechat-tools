@import "../../app.wxss";

.page-header {
  margin-bottom: 40rpx;
  padding-left: 8rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 26rpx;
  color: var(--text-second);
}

.form-card {
  opacity: 0.5;
  pointer-events: none;
  transition: all 0.3s ease;
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.config-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.color-list {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.color-option {
  flex: 1;
  border: 2rpx solid #e6e8eb;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.color-option-active {
  border-color: var(--primary-color);
  box-shadow: 0 8rpx 18rpx rgba(0, 122, 255, 0.12);
}

.color-preview {
  width: 80rpx;
  height: 100rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.preview-blue {
  background: #438EDB;
}

.preview-white {
  background: #FFFFFF;
}

.preview-red {
  background: #ED1941;
}

.color-label {
  font-size: 24rpx;
  color: var(--text-main);
  font-weight: 600;
}


.info-box {
  background: #F2F2F7;
  border-radius: var(--border-radius-md);
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.info-icon {
  width: 32rpx;
  height: 32rpx;
  background: var(--text-second);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 24rpx;
  color: var(--text-second);
  line-height: 1.6;
}
