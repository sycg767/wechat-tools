<view class="container">
  <view class="page-header">
    <view class="page-title">证件照换底色</view>
    <view class="page-desc">上传人像照片，一键切换为蓝底、白底或红底</view>
  </view>

  <file-picker
    file="{{selectedFile}}"
    accept="image"
    title="选择证件照或人像照片"
    description="支持 JPG、PNG、WebP 格式"
    bind:selected="handleFileSelected"
  />

  <view class="card form-card {{selectedFile ? 'form-active' : ''}}">
    <view class="config-title">选择背景颜色</view>
    <view class="color-list">
      <view
        wx:for="{{colorOptions}}"
        wx:key="value"
        class="color-option {{bgColor === item.value ? 'color-option-active' : ''}}"
        bindtap="handleColorChange"
        data-value="{{item.value}}"
      >
        <view class="color-preview {{item.previewClass}}"></view>
        <view class="color-label">{{item.label}}</view>
      </view>
    </view>

    <view class="notice notice-info info-box">
      <view class="notice-head">
        <view class="notice-icon">i</view>
        <view class="notice-title">处理说明</view>
      </view>
      <view class="info-text">系统会自动抠图并切换背景颜色，适合快速生成红底、蓝底或白底证件照图片。</view>
    </view>

    <button
      class="btn btn-primary {{!selectedFile ? 'btn-disabled' : ''}}"
      bindtap="handleSubmit"
      hover-class="btn-hover"
    >
      开始换底色
    </button>
  </view>
</view>
