@import "../../app.wxss";

.status-card {
  line-height: 1.8;
}

.status-row {
  font-size: 30rpx;
  color: var(--text-main);
}

.strong {
  font-weight: 800;
}

.winner {
  color: var(--error-color);
  font-weight: 800;
}

.penalty {
  color: #92400e;
  font-weight: 700;
}

.touch-zone {
  position: relative;
  height: 780rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  overflow: hidden;
}

.touch-hint {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 30rpx;
  color: var(--text-second);
  text-align: center;
  width: 100%;
}

.winner-hint {
  color: var(--error-color);
  font-weight: 700;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

.result-main {
  font-size: 34rpx;
  margin-bottom: 10rpx;
}

.result-quote {
  font-style: italic;
  color: var(--text-second);
  font-size: 28rpx;
  margin-bottom: 16rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid var(--primary-color);
}

.result-detail {
  background: #fff7ed;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.result-detail .label {
  font-size: 26rpx;
  color: #9a3412;
}

.result-time {
  font-size: 24rpx;
  color: var(--text-third);
  text-align: right;
}

.finger-point {
  position: absolute;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(59, 130, 246, 0.85);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-36rpx, -36rpx);
  font-size: 24rpx;
  font-weight: 700;
}

.winner-point {
  background: #ef4444;
  animation: blink 0.5s ease-in-out infinite alternate;
}

@keyframes blink {
  from { transform: translate(-36rpx, -36rpx) scale(1); }
  to { transform: translate(-36rpx, -36rpx) scale(1.1); }
}
