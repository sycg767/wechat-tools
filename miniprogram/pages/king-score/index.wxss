.page {
  min-height: 100vh;
  background: #f0f2f5;
  padding: 30rpx;
  box-sizing: border-box;
}

/* Header Styles */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.header-subtitle {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.header-action {
  width: 80rpx;
  height: 80rpx;
  background: #1677ff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}

.header-action.secondary {
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.icon-plus {
  color: #fff;
  font-size: 48rpx;
  font-weight: 300;
}

.icon-ocr {
  font-size: 36rpx;
}

/* OCR Status Bar */
.ocr-status-bar {
  background: #fff;
  margin-bottom: 30rpx;
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border-left: 8rpx solid #1677ff;
}

.ocr-status-bar.processing {
  border-left-color: #faad14;
}

.ocr-info {
  display: flex;
  flex-direction: column;
}

.ocr-text-main {
  font-size: 26rpx;
  font-weight: 600;
  color: #262626;
}

.ocr-text-sub {
  font-size: 20rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

.ocr-close {
  font-size: 40rpx;
  color: #bfbfbf;
  padding: 10rpx;
}

.ocr-result-card {
  margin-bottom: 24rpx;
}

.ocr-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.copy-btn {
  background: #1677ff;
  color: #fff;
  border-radius: 999rpx;
  font-size: 22rpx;
  padding: 0 20rpx;
  line-height: 1.8;
}

.ocr-raw-box {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 20rpx;
  max-height: 360rpx;
  overflow: auto;
}

.ocr-raw-text {
  font-size: 24rpx;
  color: #444;
  white-space: pre-wrap;
  word-break: break-all;
  line-height: 1.6;
}

/* Player Grid & Cards */
.player-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.player-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  position: relative;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.card-hover {
  background: rgba(0, 0, 0, 0.02);
}

.card-click-area {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
}

.player-actions {
  position: relative;
  z-index: 2;
}

.player-card.warning {
  background: #fff1f0;
  border: 1rpx solid #ffa39e;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.player-name-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.player-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.player-actions {
  display: flex;
  gap: 8rpx;
}

.player-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
}

.player-alias {
  font-size: 20rpx;
  color: #8c8c8c;
  line-height: 1.4;
  word-break: break-all;
}

.player-link {
  font-size: 22rpx;
  color: #1677ff;
  background: #e6f4ff;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.deduction-badge {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.3s ease;
}

.deduction-badge.show {
  opacity: 1;
  transform: translateY(0);
}

.score-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin: 30rpx 0;
}

.score-value {
  font-size: 72rpx;
  font-weight: 800;
  color: #1677ff;
  font-family: 'DIN Alternate', sans-serif;
}

.player-card.warning .score-value {
  color: #ff4d4f;
}

.score-unit {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-left: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 20rpx;
  color: #8c8c8c;
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #595959;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: #f0f0f0;
}

.ocr-hit,
.ocr-miss {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.ocr-hit-title {
  font-size: 22rpx;
  color: #1677ff;
  font-weight: 600;
}

.ocr-hit-line,
.ocr-miss {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.5;
  word-break: break-all;
}

/* Animations */
@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

.pulse {
  animation: pulse 0.4s ease-out;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 16rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.btn {
  background: #1677ff;
  color: #fff;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 88rpx;
  font-size: 28rpx;
  padding: 0;
  width: 100% !important;
  line-height: 1;
  margin: 0;
}

.btn::after {
  border: none;
}

.result-btn.good {
  background: #0a8f4d;
}

.result-btn.bad {
  background: #b42318;
}

.result-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
}

.quick-tip {
  margin-top: 12rpx;
}

.flex {
  flex: 1;
}

.summary {
  color: #666;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

/* Calendar Styles */
.calendar-card {
  padding: 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.calendar-nav {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-btn {
  padding: 10rpx 20rpx;
  color: #1677ff;
  font-size: 24rpx;
}

.current-month {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 20rpx;
}

.calendar-weekdays text {
  font-size: 22rpx;
  color: #8c8c8c;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.calendar-day {
  height: 80rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 12rpx;
  position: relative;
}

.calendar-day.today {
  background: #e6f4ff;
}

.calendar-day.selected {
  border: 2rpx solid #1677ff;
}

.day-num {
  font-size: 26rpx;
  color: #262626;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-top: 4rpx;
}

.calendar-day.good .day-dot {
  background: #52c41a;
}

.calendar-day.bad .day-dot {
  background: #ff4d4f;
}

.calendar-tip {
  text-align: center;
  font-size: 22rpx;
  color: #bfbfbf;
  margin-top: 20rpx;
}

/* History Detail Styles */
.history-detail {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.detail-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
}

.detail-summary {
  font-size: 22rpx;
  color: #8c8c8c;
  margin-bottom: 24rpx;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-item {
  background: #f7f8fa;
  padding: 20rpx;
  border-radius: 16rpx;
}

.detail-item-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.detail-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #262626;
}

.detail-score {
  font-size: 26rpx;
  font-weight: 700;
  color: #1677ff;
}

.detail-item-sub {
  font-size: 22rpx;
  color: #595959;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag.good {
  color: #52c41a;
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
}

.tag.bad {
  color: #ff4d4f;
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
}

.empty-state {
  grid-column: span 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: #bfbfbf;
  font-size: 28rpx;
}

/* Modal Styles */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
}

.modal-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  transform: translateY(100%);
  transition: all 0.3s ease;
}

.modal.show .modal-container {
  transform: translateY(0);
}

.modal-header {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 40rpx;
  text-align: center;
}

.modal-input {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #595959;
}

.modal-btn.confirm {
  background: #1677ff;
  color: #fff;
}
