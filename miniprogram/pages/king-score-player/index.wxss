@import "../../app.wxss";

.page {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 32rpx;
  box-sizing: border-box;
}

.header-card,
.chart-card,
.hero-card,
.record-card {
  background: linear-gradient(180deg, #FFFFFF 0%, #FBFBFD 100%);
  border-radius: var(--border-radius-apple);
  padding: 28rpx;
  border: var(--border-premium);
  box-shadow: var(--shadow-premium);
}

.header-card,
.chart-card,
.hero-card {
  margin-bottom: 24rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 20rpx;
}

.summary-row {
  display: grid;
  gap: 16rpx;
}

.summary-row-4 {
  grid-template-columns: repeat(4, 1fr);
}

.summary-item {
  background: var(--card-subtle);
  border-radius: var(--border-radius-lg);
  padding: 16rpx 12rpx;
  text-align: center;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main);
}

.summary-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-second);
}

.chart-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.chart-title,
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.chart-desc,
.chart-foot {
  font-size: 22rpx;
  color: var(--text-second);
  line-height: 1.6;
}

.chart-desc {
  margin-top: 8rpx;
}

.chart-canvas {
  width: 100%;
  display: block;
  background: #FFFFFF;
  border-radius: var(--border-radius-lg);
}

.chart-foot {
  margin-top: 14rpx;
}

.empty {
  color: var(--text-second);
  text-align: center;
  padding: 120rpx 0;
  font-size: 28rpx;
}

.record-card {
  margin-bottom: 20rpx;
}

.record-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.record-date-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.mvp-crown { font-size: 28rpx; }

.record-date {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
}

.record-badges {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.mini-tag {
  font-size: 22rpx;
  line-height: 1;
  padding: 8rpx 14rpx;
  border-radius: var(--border-radius-pill);
}

.mini-tag.win { color: var(--success-color); background: var(--success-soft); }
.mini-tag.lose { color: var(--error-color); background: var(--error-soft); }
.mini-tag.neutral { color: var(--text-second); background: var(--card-subtle); }
.mini-tag.mvp { color: var(--warning-color); background: var(--warning-soft); }

.record-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  background: var(--card-subtle);
}

.meta-item.hero,
.meta-item.kda,
.meta-item.rating { background: var(--card-subtle); }

.meta-item.rating.high-score .meta-value { color: var(--warning-color); }
.meta-item.rating.low-score .meta-value { color: var(--error-color); }

.card-win { border-left: 8rpx solid var(--success-color) !important; }
.card-lose { border-left: 8rpx solid var(--error-color) !important; }
.card-mvp { background: linear-gradient(180deg, #FFFFFF 0%, #FFF9EE 100%) !important; }

.hero-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.hero-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: var(--card-subtle);
  border-radius: var(--border-radius-lg);
}

.hero-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.hero-data {
  font-size: 24rpx;
  color: var(--text-second);
  display: flex;
  gap: 16rpx;
}

.win-rate {
  color: var(--text-main);
  font-weight: 600;
}

.meta-label {
  font-size: 20rpx;
  color: var(--text-second);
}

.meta-value {
  font-size: 24rpx;
  color: var(--text-main);
  font-weight: 600;
  word-break: break-all;
}
