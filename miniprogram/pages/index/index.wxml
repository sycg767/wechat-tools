<view class="container">
  <!-- Header Section -->
  <view class="page-header">
    <view class="header-left">
      <view class="header-title">工具箱</view>
    </view>
    <view class="header-right">
      <view class="history-pill" bindtap="goToTasks">
        <view class="history-icon"></view>
        <text>历史</text>
      </view>
    </view>
  </view>

  <!-- Category View Mode -->
  <view wx:if="{{viewMode === 'categories'}}" class="view-fade-in">
    <view class="bento-grid">
      <block wx:for="{{categorySections}}" wx:key="id">
        <view
          class="bento-item {{item.size || 'small'}} {{item.theme}}"
          bindtap="handleCategoryTap"
          data-category-id="{{item.id}}"
          hover-class="bento-item-hover"
        >
          <view class="card-inner">
            <view class="icon-wrapper {{item.iconClass}}">
              <view class="bento-icon" style="-webkit-mask-image: {{item.maskImage}}; mask-image: {{item.maskImage}};"></view>
            </view>
            <view class="content-wrapper">
              <view class="title">{{item.title}}</view>
              <view class="desc">{{item.desc}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- Sub-Tool View Mode -->
  <view wx:if="{{viewMode === 'sub'}}" class="view-fade-in">
    <view class="sub-header" bindtap="goBackToCategories">
      <view class="back-icon"></view>
      <text class="sub-title">{{currentCategory.title}}</text>
    </view>

    <view class="bento-grid">
      <block wx:for="{{currentCategory.items}}" wx:key="id">
        <view
          class="bento-item small {{item.disabled ? 'disabled' : ''}}"
          bindtap="handleToolTap"
          data-tool-id="{{item.id}}"
          data-path="{{item.path}}"
          data-disabled="{{item.disabled}}"
          hover-class="bento-item-hover"
        >
          <view class="card-inner">
            <view class="icon-wrapper {{item.iconClass}}">
              <view class="bento-icon" style="-webkit-mask-image: {{item.maskImage}}; mask-image: {{item.maskImage}};"></view>
            </view>
            <view class="content-wrapper">
              <view class="title">{{item.title}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

</view>
