<view class="container">
  <!-- Header Section -->
  <view class="page-header">
    <view class="header-left">
      <view class="header-title">工具箱</view>
    </view>
    <view class="header-right">
      <view class="history-pill" bindtap="goToTasks">
        <view class="history-icon"></view>
        <text>历史</text>
      </view>
    </view>
  </view>

  <!-- Search Bar -->
  <view class="search-bar-container view-fade-in" wx:if="{{viewMode === 'categories' || viewMode === 'search'}}">
    <view class="search-inner {{viewMode === 'search' ? 'active' : ''}}">
      <view class="search-icon"></view>
      <input
        class="search-input"
        placeholder="搜索工具..."
        placeholder-class="search-placeholder"
        bindinput="onSearchInput"
        bindfocus="onSearchFocus"
        confirm-type="search"
        value="{{searchQuery}}"
      />
      <view class="clear-icon" wx:if="{{searchQuery}}" bindtap="onClearSearch"></view>
    </view>
    <text class="cancel-btn" wx:if="{{viewMode === 'search'}}" bindtap="onCancelSearch">取消</text>
  </view>

  <!-- Category View Mode -->
  <view wx:if="{{viewMode === 'categories'}}" class="view-fade-in">
    <view class="bento-grid">
      <block wx:for="{{categorySections}}" wx:key="id">
        <view
          class="bento-item {{item.theme}}"
          bindtap="handleHomeCardTap"
          data-category-id="{{item.categoryId}}"
          data-tool-id="{{item.toolId}}"
          data-path="{{item.path}}"
          data-disabled="{{item.disabled}}"
          hover-class="bento-item-hover"
        >
          <view class="card-inner">
            <view class="card-glow"></view>
            <view class="icon-wrapper {{item.iconClass}}">
              <view class="bento-icon" style="-webkit-mask-image: {{item.maskImage}}; mask-image: {{item.maskImage}};"></view>
            </view>
            <view class="content-wrapper">
              <view class="title">{{item.title}}</view>
              <view class="desc">{{item.desc}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- Search Results Mode -->
  <view wx:if="{{viewMode === 'search'}}" class="view-fade-in search-results">
    <view class="bento-grid">
      <block wx:for="{{searchResults}}" wx:key="id">
        <view
          class="bento-item {{item.disabled ? 'disabled' : ''}}"
          bindtap="handleToolTap"
          data-tool-id="{{item.id}}"
          data-path="{{item.path}}"
          data-disabled="{{item.disabled}}"
          hover-class="bento-item-hover"
        >
          <view class="card-inner">
            <view class="card-glow"></view>
            <view class="icon-wrapper {{item.iconClass}}">
              <view class="bento-icon" style="-webkit-mask-image: {{item.maskImage}}; mask-image: {{item.maskImage}};"></view>
            </view>
            <view class="content-wrapper">
              <view class="title">{{item.title}}</view>
              <view class="desc">{{item.desc}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>
    <view class="no-results" wx:if="{{searchResults.length === 0 && searchQuery}}">
      <view class="no-results-icon"></view>
      <text>未找到相关工具</text>
    </view>
  </view>

  <!-- Sub-Tool View Mode -->
  <view wx:if="{{viewMode === 'sub'}}" class="view-fade-in">
    <view class="sub-header">
      <view class="back-button-hit" bindtap="goBackToCategories">
        <view class="back-icon"></view>
      </view>
      <text class="sub-title">{{currentCategory.title}}</text>
    </view>

    <view class="bento-grid">
      <block wx:for="{{currentCategory.items}}" wx:key="id">
        <view
          class="bento-item {{item.disabled ? 'disabled' : ''}}"
          bindtap="handleToolTap"
          data-tool-id="{{item.id}}"
          data-path="{{item.path}}"
          data-disabled="{{item.disabled}}"
          hover-class="bento-item-hover"
        >
          <view class="card-inner">
            <view class="card-glow"></view>
            <view class="icon-wrapper {{item.iconClass}}">
              <view class="bento-icon" style="-webkit-mask-image: {{item.maskImage}}; mask-image: {{item.maskImage}};"></view>
            </view>
            <view class="content-wrapper">
              <view class="title">{{item.title}}</view>
              <view class="desc">{{item.desc}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

</view>
