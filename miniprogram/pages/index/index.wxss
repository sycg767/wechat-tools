.container {
  padding: 40rpx 40rpx 200rpx; /* 底部留出底栏空间 */
  background-color: #F4F5F7;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Page Header */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
  padding: 20rpx 8rpx;
}

.header-title {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: -1rpx;
}

.history-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FFFFFF;
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  border: 1px solid rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.history-pill:active {
  background: rgba(0, 0, 0, 0.1);
  transform: scale(0.95);
}

.history-icon {
  width: 36rpx;
  height: 36rpx;
  background-color: #111827;
  mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>');
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>');
  mask-size: contain;
  -webkit-mask-size: contain;
}

.history-pill text {
  display: none; /* 隐藏文字，只保留图标 */
}

.arrow-right {
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid #9CA3AF;
  border-right: 2rpx solid #9CA3AF;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

/* View Transitions */
.view-fade-in {
  animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Search Bar */
.search-bar-container {
  margin-bottom: 48rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.search-inner {
  flex: 1;
  background: #F0F1F4;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 16rpx;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.search-inner.active {
  background: #FFFFFF;
  border-color: #111827;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  background-color: #9CA3AF;
  mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>');
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>');
  mask-size: contain;
  -webkit-mask-size: contain;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #111827;
}

.search-placeholder {
  color: #9CA3AF;
}

.clear-icon {
  width: 32rpx;
  height: 32rpx;
  background-color: #9CA3AF;
  mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>');
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>');
  mask-size: contain;
  -webkit-mask-size: contain;
  flex-shrink: 0;
}

.cancel-btn {
  font-size: 30rpx;
  color: #111827;
  font-weight: 500;
  white-space: nowrap;
}

/* Search Results */
.search-results {
  min-height: 400rpx;
}

.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
  color: #9CA3AF;
}

.no-results-icon {
  width: 120rpx;
  height: 120rpx;
  background-color: #E5E7EB;
  margin-bottom: 24rpx;
  mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>');
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>');
  mask-size: contain;
  -webkit-mask-size: contain;
}

/* Sub Header */
.sub-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 40rpx;
  margin-left: -20rpx; /* 抵消返回按钮热区的内边距，保持视觉对齐 */
}

.back-button-hit {
  padding: 20rpx; /* 扩大点击热区 */
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #111827;
  border-bottom: 4rpx solid #111827;
  transform: rotate(45deg);
}

.sub-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #111827;
}

/* Bento Grid */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
  padding: 0 4rpx;
}

.bento-item {
  position: relative;
  height: 244rpx;
  background: #FFFFFF;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 28rpx rgba(17, 24, 39, 0.05);
  border: 1rpx solid rgba(17, 24, 39, 0.04);
  overflow: hidden;
  transition: all 0.32s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.theme-yellow { background: linear-gradient(145deg, #FFFFFF 42%, #FFF9D7 100%); }
.theme-rose { background: linear-gradient(145deg, #FFFFFF 42%, #FFE8ED 100%); }
.theme-blue { background: linear-gradient(145deg, #FFFFFF 42%, #E8F1FF 100%); }
.theme-emerald { background: linear-gradient(145deg, #FFFFFF 42%, #E3FFF2 100%); }
.theme-purple { background: linear-gradient(145deg, #FFFFFF 42%, #F0E9FF 100%); }

.bento-item-hover {
  transform: scale(0.97) translateY(3rpx);
  box-shadow: 0 4rpx 10rpx rgba(17, 24, 39, 0.04);
  filter: brightness(0.98);
}

.card-inner {
  padding: 24rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.card-glow {
  position: absolute;
  top: -72rpx;
  right: -72rpx;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.86) 0%, rgba(255,255,255,0) 68%);
  pointer-events: none;
  z-index: -1;
}

.icon-wrapper {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: inset 0 2rpx 4rpx rgba(255, 255, 255, 0.82);
}

.bento-icon {
  width: 34rpx;
  height: 34rpx;
  background-color: currentColor;
  mask-size: contain;
  mask-repeat: no-repeat;
  mask-position: center;
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
}

/* Icon Colors */
.icon-pdf-word, .icon-pdf-excel, .icon-pdf-merge, .icon-pdf-split, .icon-pdf-watermark, .icon-pdf-manage, .icon-word-pdf, .icon-signature {
  background-color: #FFF1F2;
  color: #F43F5E;
}

.icon-image, .icon-id-photo {
  background-color: #EFF6FF;
  color: #3B82F6;
}

.icon-rename, .icon-csv-excel, .icon-vault, .icon-qr-code, .icon-unit {
  background-color: #ECFDF5;
  color: #10B981;
}

.icon-eat, .icon-random {
  background-color: #FEFCE8;
  color: #EAB308;
}

.icon-wooden-fish {
  background-color: #FFF7ED;
  color: #C2410C;
}

.content-wrapper {
  min-width: 0;
}

.title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.22;
  letter-spacing: -0.4rpx;
}

.desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7C8491;
  line-height: 1.38;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tag {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  background: #F3F4F6;
  color: #9CA3AF;
  border-radius: 100rpx;
}

/* Floating Pill Tabbar */
.tabbar-wrapper {
  position: fixed;
  bottom: 60rpx; /* 稍微调高一点，避免遮挡内容 */
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  justify-content: center;
  pointer-events: none; /* 容器不拦截点击 */
}

.tabbar-pill {
  pointer-events: auto; /* 药丸本身拦截点击 */
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 100rpx;
  padding: 20rpx 60rpx;
  display: flex;
  align-items: center;
  gap: 80rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  background-color: #9CA3AF;
  transition: all 0.3s ease;
  mask-size: contain;
  mask-repeat: no-repeat;
  mask-position: center;
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
}

.tab-item.active .tab-icon {
  background-color: #111827;
}

.tab-dot {
  width: 6rpx;
  height: 6rpx;
  background: #111827;
  border-radius: 50%;
  position: absolute;
  bottom: -4rpx;
}

/* SVG Icons via Mask */
.icon-home {
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>');
}

.icon-task {
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>');
}

.icon-user {
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>');
}

.disabled {
  opacity: 0.5;
  filter: grayscale(1);
}
