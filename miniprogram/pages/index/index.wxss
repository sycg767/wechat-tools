@import "../../app.wxss";

.hero-section {
  position: relative;
  padding: 60rpx 40rpx 80rpx;
  background: linear-gradient(135deg, #007AFF 0%, #0056B3 100%);
  border-radius: 0 0 60rpx 60rpx;
  margin: -32rpx -32rpx 40rpx -32rpx;
  overflow: hidden;
  color: #ffffff;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  font-weight: 300;
}

.hero-bg-circle {
  position: absolute;
  right: -100rpx;
  top: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  z-index: 1;
}

.tool-section {
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 10rpx;
}

.section-header-main {
  margin-bottom: 20rpx;
}

.section-header-sub {
  margin-bottom: 18rpx;
}

.section-title {
  margin: 0;
  font-size: 36rpx;
}

.section-title-sub {
  font-size: 30rpx;
  color: #444;
}

.section-more {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.tool-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.tool-item-wrapper {
  width: 100%;
}

.tool-item {
  background: var(--card-bg);
  border-radius: 28rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--shadow);
  transition: all 0.2s ease;
}

.tool-item-hover .tool-item {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.08);
}

.tool-icon-box {
  width: 92rpx;
  height: 92rpx;
  border-radius: 22rpx;
  margin-right: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.icon-default { background: #eef2f6; }
.icon-rename { background: #E5F1FF; }
.icon-pdf-word { background: #FFF0F0; }
.icon-pdf-excel { background: #F0FFF4; }
.icon-image { background: #FFF9E6; }
.icon-id-photo { background: #EEF4FF; }
.icon-pdf-merge { background: #F0F0FF; }
.icon-pdf-split { background: #F0F7FF; }
.icon-pdf-watermark { background: #EAF6FF; }
.icon-word-pdf { background: #FFF3E8; }
.icon-csv-excel { background: #E8FAF0; }
.icon-qr-code { background: #F3F6FF; }
.icon-signature { background: #FFF2F4; }
.icon-unit { background: #F5F4FF; }
.icon-random { background: #EEFDF5; }
.icon-eat { background: #FFF0F6; }
.icon-pdf-manage { background: #F0F5FF; }
.icon-tasks { background: #F5F5F7; }

.tool-icon-inner {
  width: 46rpx;
  height: 46rpx;
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
  opacity: 0.8;
}

.icon-default .tool-icon-inner { color: #8b95a1; }
.icon-rename .tool-icon-inner { color: #007AFF; }
.icon-pdf-word .tool-icon-inner { color: #FF3B30; border-radius: 4rpx; }
.icon-pdf-excel .tool-icon-inner { color: #34C759; }
.icon-image .tool-icon-inner { color: #FF9500; border-radius: 50%; }
.icon-id-photo .tool-icon-inner { color: #4C6FFF; border-radius: 18rpx; }
.icon-pdf-merge .tool-icon-inner { color: #5856D6; }
.icon-pdf-split .tool-icon-inner { color: #007AFF; }
.icon-pdf-watermark .tool-icon-inner { color: #2f8cff; }
.icon-word-pdf .tool-icon-inner { color: #FF7A00; border-radius: 6rpx; }
.icon-csv-excel .tool-icon-inner { color: #21a45d; border-radius: 6rpx; }
.icon-qr-code .tool-icon-inner { color: #3f51b5; border-radius: 6rpx; }
.icon-signature .tool-icon-inner { color: #d14d72; border-radius: 6rpx; }
.icon-unit .tool-icon-inner { color: #6c63ff; border-radius: 6rpx; }
.icon-random .tool-icon-inner { color: #07c160; border-radius: 50%; }
.icon-eat .tool-icon-inner { color: #EB2F96; border-radius: 50%; }
.icon-pdf-manage .tool-icon-inner { color: #2F54EB; border-radius: 4rpx; }
.icon-tasks .tool-icon-inner { color: #86868B; }

.tool-info {
  flex: 1;
}

.tool-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.tool-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.tool-tag,
.tool-recent {
  display: inline-block;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.tool-tag {
  background: var(--primary-light);
  color: var(--primary-color);
}

.tool-recent {
  background: #eef8ff;
  color: #2f8cff;
}

.favorite-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 50%;
  background: #f3f5f8;
  color: #b0b7c3;
  font-size: 30rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.favorite-btn.active {
  background: #fff5d8;
  color: #f6a500;
}

.tool-arrow {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  width: 14rpx;
  height: 14rpx;
  border-top: 4rpx solid #D1D1D6;
  border-right: 4rpx solid #D1D1D6;
  transform: rotate(45deg);
}

.tool-disabled {
  opacity: 0.6;
  filter: grayscale(1);
}

.footer-tips {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-second);
  margin-top: 50rpx;
  padding-bottom: 40rpx;
}
