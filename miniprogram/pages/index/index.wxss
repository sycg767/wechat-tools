.container {
  padding: 40rpx 40rpx 200rpx; /* 底部留出底栏空间 */
  background-color: #FAFAFA;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Page Header */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 64rpx;
  padding: 20rpx 8rpx;
}

.header-title {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: -2rpx;
}

.history-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(0, 0, 0, 0.05);
  padding: 12rpx 28rpx;
  border-radius: 100rpx;
  transition: all 0.3s ease;
}

.history-pill:active {
  background: rgba(0, 0, 0, 0.1);
  transform: scale(0.95);
}

.history-icon {
  width: 28rpx;
  height: 28rpx;
  background-color: var(--text-main);
  mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>');
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>');
  mask-size: contain;
  -webkit-mask-size: contain;
}

.history-pill text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-main);
}

.arrow-right {
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid #9CA3AF;
  border-right: 2rpx solid #9CA3AF;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

/* View Transitions */
.view-fade-in {
  animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Sub Header */
.sub-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
  padding: 10rpx;
}

.back-icon {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid #111827;
  border-bottom: 4rpx solid #111827;
  transform: rotate(45deg);
}

.sub-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #111827;
}

/* Bento Grid */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-auto-rows: minmax(200rpx, auto); /* 移除固定高度限制，允许内容撑开 */
  gap: 32rpx; /* 增加网格间距，提升呼吸感 */
}

.bento-item {
  position: relative;
  background: #FFFFFF;
  border-radius: var(--border-radius-apple);
  box-shadow: var(--shadow-premium);
  border: var(--border-premium);
  overflow: hidden;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
}

/* Apple-Style Subtle Gradients */
.theme-yellow { background: linear-gradient(165deg, #FFFFFF 60%, #FFF9E6 100%); }
.theme-rose { background: linear-gradient(165deg, #FFFFFF 60%, #FFF0F0 100%); }
.theme-blue { background: linear-gradient(165deg, #FFFFFF 60%, #F0F7FF 100%); }
.theme-emerald { background: linear-gradient(165deg, #FFFFFF 60%, #F0FFF4 100%); }

.bento-item.wide {
  grid-column: span 2;
}

.bento-item.large {
  grid-column: span 2;
  grid-row: span 2;
}

.bento-item-hover {
  transform: scale(0.97) translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  filter: brightness(0.98);
}

.card-inner {
  padding: 48rpx; /* 显著增加内边距，彻底解决贴边问题 */
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start; /* 改为顶部对齐，配合 gap 控制间距 */
  gap: 24rpx; /* 统一子元素间距 */
  box-sizing: border-box;
}

/* Icon Styles */
.icon-wrapper {
  width: 96rpx; /* 增大图标容器 */
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx; /* 减少底部 margin，改由父容器 gap 控制 */
}

.bento-icon {
  width: 44rpx;
  height: 44rpx;
  background-color: currentColor;
  mask-size: contain;
  mask-repeat: no-repeat;
  mask-position: center;
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
}

/* Icon Colors */
.icon-pdf-word, .icon-pdf-excel, .icon-pdf-merge, .icon-pdf-split, .icon-pdf-watermark, .icon-pdf-manage {
  background-color: #FFF1F2;
  color: #F43F5E;
}

.icon-image, .icon-id-photo {
  background-color: #EFF6FF;
  color: #3B82F6;
}

.icon-rename, .icon-csv-excel {
  background-color: #ECFDF5;
  color: #10B981;
}

.icon-eat, .icon-random {
  background-color: #FEFCE8;
  color: #EAB308;
}

.title {
  font-size: 38rpx; /* 进一步优化标题字号 */
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.3; /* 增加行高，避免拥挤 */
  letter-spacing: -0.5rpx;
}

.desc {
  font-size: 26rpx;
  color: var(--text-second);
  margin-top: 4rpx; /* 减少顶部 margin，改由父容器 gap 控制 */
  line-height: 1.6; /* 增加行高，提升易读性 */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tag {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  background: #F3F4F6;
  color: #9CA3AF;
  border-radius: 100rpx;
}

/* Floating Pill Tabbar */
.tabbar-wrapper {
  position: fixed;
  bottom: 60rpx; /* 稍微调高一点，避免遮挡内容 */
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  justify-content: center;
  pointer-events: none; /* 容器不拦截点击 */
}

.tabbar-pill {
  pointer-events: auto; /* 药丸本身拦截点击 */
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 100rpx;
  padding: 20rpx 60rpx;
  display: flex;
  align-items: center;
  gap: 80rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  background-color: #9CA3AF;
  transition: all 0.3s ease;
  mask-size: contain;
  mask-repeat: no-repeat;
  mask-position: center;
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
}

.tab-item.active .tab-icon {
  background-color: #111827;
}

.tab-dot {
  width: 6rpx;
  height: 6rpx;
  background: #111827;
  border-radius: 50%;
  position: absolute;
  bottom: -4rpx;
}

/* SVG Icons via Mask */
.icon-home {
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>');
}

.icon-task {
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>');
}

.icon-user {
  -webkit-mask-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>');
}

.disabled {
  opacity: 0.5;
  filter: grayscale(1);
}
