@import "../../app.wxss";

.upload-card {
  margin-bottom: 32rpx;
}

.summary-box {
  margin-bottom: 28rpx;
}

.loading-tip {
  padding: 20rpx 0;
  font-size: 24rpx;
  color: var(--text-second);
}

.preview-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.page-card {
  padding: 22rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  border: 1px solid rgba(17, 24, 39, 0.04);
}

.page-card-deleted {
  opacity: 0.62;
}

.thumb-wrap {
  height: 320rpx;
  border-radius: 22rpx;
  background: #FFFFFF;
  border: 1px solid rgba(17, 24, 39, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.thumb {
  width: 100%;
  height: 100%;
}

.page-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin: 18rpx 0;
}

.page-title-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.page-rotation {
  font-size: 24rpx;
  color: var(--text-second);
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mini-btn {
  min-width: 132rpx;
  padding: 0 18rpx;
  border-radius: var(--border-radius-pill);
  background: #FFFFFF;
  color: var(--text-main);
  border: 1px solid rgba(17, 24, 39, 0.06);
  font-size: 22rpx;
}

.mini-btn-delete {
  background: var(--error-soft);
  color: var(--error-color);
}

.mini-btn-restore {
  background: var(--success-soft);
  color: var(--success-color);
}
