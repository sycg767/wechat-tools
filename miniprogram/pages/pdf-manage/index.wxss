@import "../../app.wxss";

.container {
  padding: 30rpx;
  background-color: #f7f8fa;
  min-height: 100vh;
}

.header {
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.summary-row {
  margin-bottom: 20rpx;
}

.summary-text {
  font-size: 24rpx;
  color: #666;
}

.summary-warn {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #ff9500;
}

.loading-tip {
  font-size: 24rpx;
  color: #666;
  padding: 20rpx 0;
}

.preview-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.page-card {
  background: #f7f9fc;
  border-radius: 14rpx;
  padding: 18rpx;
  border: 2rpx solid #e8edf5;
}

.page-card-deleted {
  opacity: 0.6;
}

.thumb-wrap {
  height: 300rpx;
  border-radius: 10rpx;
  background: #fff;
  border: 1rpx solid #edf0f5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.thumb {
  width: 100%;
  height: 100%;
}

.page-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 14rpx 0;
}

.page-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.page-rotation {
  font-size: 24rpx;
  color: #666;
}

.action-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.mini-btn {
  min-width: 120rpx;
}

.mini-btn-delete {
  background: #ffeaea;
  color: #d93025;
}

.mini-btn-restore {
  background: #eaf8ef;
  color: #1e8e3e;
}
