<view class="container">
  <view class="page-header">
    <view class="page-title">任务历史</view>
    <view class="page-desc">查看最近 24 小时内的文件处理记录</view>
  </view>

  <view wx:if="{{tasks.length === 0}}" class="empty-state">
    <view class="empty-icon"></view>
    <view class="empty-title">暂无任务记录</view>
    <view class="empty-desc">提交文件处理后，结果会出现在这里</view>
    <button class="btn btn-secondary mt-20" bindtap="goToHome">去处理文件</button>
  </view>

  <view class="task-list" wx:else>
    <block wx:for="{{tasks}}" wx:key="taskId">
      <view
        class="card task-card"
        bindtap="handleTaskTap"
        data-task-id="{{item.taskId}}"
        hover-class="card-active"
      >
        <view class="task-header">
          <view class="task-type-tag">{{item.toolType || '工具'}}</view>
          <view class="task-status-tag {{item.status === 'SUCCESS' ? 'status-success' : (item.status === 'FAIL' ? 'status-fail' : 'status-processing')}}">
            {{item.status === 'SUCCESS' ? '已完成' : (item.status === 'FAIL' ? '失败' : '处理中')}}
          </view>
        </view>
        
        <view class="task-body">
          <view class="task-filename">{{item.sourceFileName || '未命名文件'}}</view>
          <view class="task-result" wx:if="{{item.resultFileName}}">
            <text class="result-label">结果：</text>
            <text class="result-value">{{item.resultFileName}}</text>
          </view>
        </view>
        
        <view class="task-footer">
          <view class="task-time">{{item.updatedAtText || '刚刚'}}</view>
          <view class="task-action">查看详情 ></view>
        </view>
      </view>
    </block>
  </view>
</view>
