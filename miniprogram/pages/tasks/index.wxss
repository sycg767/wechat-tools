@import "../../app.wxss";

.page-header {
  margin-bottom: 40rpx;
  padding-left: 8rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 26rpx;
  color: var(--text-second);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: #F2F2F7;
  border-radius: 50%;
  margin-bottom: 40rpx;
  position: relative;
}

.empty-icon::after {
  content: '';
  position: absolute;
  width: 60rpx;
  height: 80rpx;
  border: 4rpx solid #D1D1D6;
  border-radius: 8rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-second);
  text-align: center;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.task-card {
  margin-bottom: 0;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.task-type-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  background: #F2F2F7;
  color: var(--text-second);
  border-radius: 20rpx;
}

.task-status-tag {
  font-size: 22rpx;
  font-weight: 600;
}

.status-success { color: var(--success-color); }
.status-fail { color: var(--error-color); }
.status-processing { color: var(--primary-color); }

.task-body {
  margin-bottom: 24rpx;
}

.task-filename {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 8rpx;
  word-break: break-all;
}

.task-result {
  font-size: 24rpx;
}

.result-label {
  color: var(--text-second);
}

.result-value {
  color: var(--primary-color);
}

.task-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid #F2F2F7;
}

.task-time {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.task-action {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
}
