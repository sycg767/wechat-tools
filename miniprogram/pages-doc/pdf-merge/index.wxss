@import "../../app.wxss";

.page-header {
  margin-bottom: 40rpx;
  padding-left: 8rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 26rpx;
  color: var(--text-second);
}

.file-list-card {
  padding: 32rpx;
  margin-bottom: 40rpx;
  background: transparent !important;
  box-shadow: none !important;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.file-list {
  position: relative;
  margin-bottom: 32rpx;
}

.file-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid transparent;
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  z-index: 1;
}

.file-item.dragging {
  z-index: 100;
  background: #F8F9FF;
  border-color: var(--primary-color);
  box-shadow: 0 12rpx 40rpx rgba(0, 122, 255, 0.15);
  transform: scale(1.02);
  opacity: 0.95;
}

.drag-handle {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  padding: 20rpx;
  margin-left: -10rpx;
  margin-right: 10rpx;
}

.drag-line {
  width: 32rpx;
  height: 4rpx;
  background: #D1D1D6;
  border-radius: 2rpx;
}

.dragging .drag-line {
  background: var(--primary-color);
}

.file-info {
  flex: 1;
  margin-right: 24rpx;
  overflow: hidden;
}

.file-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
  margin-bottom: 4rpx;
}

.file-size {
  font-size: 22rpx;
  color: var(--text-second);
}

.file-action {
  padding: 16rpx;
  margin-right: -10rpx;
}

.empty-tip {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-second);
  padding: 80rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  border: 2rpx dashed #D1D1D6;
}

.add-btn {
  width: 100% !important;
  background: #ffffff !important;
  color: var(--primary-color) !important;
  border: 2rpx dashed var(--primary-color) !important;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx !important;
  margin-top: 20rpx;
}

.plus {
  font-size: 36rpx;
  margin-right: 8rpx;
  margin-top: -4rpx;
}

.form-card {
  margin: 0 32rpx 120rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  opacity: 0.5;
  pointer-events: none;
  transition: all 0.3s ease;
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.form-item {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.input {
  background: #F2F2F7;
  height: 88rpx;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.tip {
  font-size: 22rpx;
  color: var(--text-second);
  margin-top: 12rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 40rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  z-index: 200;
}

.bar-active {
  transform: translateY(0);
}