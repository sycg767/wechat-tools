<view class="container">
  <view class="page-header">
    <view class="page-title">PDF 转图片</view>
    <view class="page-desc">将 PDF 页面导出为 PNG 或 JPG，单页直接出图，多页自动打包为 zip。</view>
  </view>

  <file-picker file="{{selectedFile}}" accept="pdf" bind:selected="handleFileSelected" />

  <view class="card form-card {{selectedFile ? 'form-active' : ''}}">
    <view class="form-item">
      <view class="label">图片格式</view>
      <view class="segmented">
        <view
          class="segmented-item {{format === 'png' ? 'segmented-item-active' : ''}}"
          data-format="png"
          bindtap="handleFormatChange"
        >PNG</view>
        <view
          class="segmented-item {{format === 'jpg' ? 'segmented-item-active' : ''}}"
          data-format="jpg"
          bindtap="handleFormatChange"
        >JPG</view>
      </view>
      <view class="tip">PNG 更清晰，JPG 体积通常更小。</view>
    </view>

    <view class="form-item">
      <view class="label">清晰度</view>
      <view class="segmented">
        <view
          wx:for="{{dpiOptions}}"
          wx:key="value"
          class="segmented-item {{dpi === item.value ? 'segmented-item-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="handleDpiChange"
        >{{item.label}}</view>
      </view>
      <view class="tip">标准适合日常预览，高清更适合打印或细节保留。</view>
    </view>

    <view class="form-item">
      <view class="label">页码范围</view>
      <input
        class="input"
        placeholder="留空导出全部，如 1-3,5"
        value="{{range}}"
        bindinput="handleRangeInput"
      />
      <view class="tip">单页会直接生成图片，多页会自动打包为 zip。</view>
    </view>

    <view class="notice notice-info info-box">
      <view class="notice-head">
        <view class="notice-icon">i</view>
        <view class="notice-title">导出说明</view>
      </view>
      <view class="info-text">页数较多或分辨率较高时，处理时间会更久；生成完成后可在任务详情页预览、保存或分享结果。</view>
    </view>

    <button
      class="btn btn-primary {{!selectedFile ? 'btn-disabled' : ''}}"
      bindtap="handleSubmit"
      hover-class="btn-hover"
    >
      开始转换
    </button>
  </view>
</view>
