@import "../../app.wxss";

.form-card {
  opacity: 0.55;
  pointer-events: none;
  transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.form-active {
  opacity: 1;
  pointer-events: auto;
}

.form-item {
  margin-bottom: 36rpx;
}

.segmented {
  display: flex;
  gap: 16rpx;
}

.segmented-item {
  flex: 1;
  height: 88rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  border: 1px solid rgba(17, 24, 39, 0.08);
  color: var(--text-second);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
}

.segmented-item-active {
  background: var(--primary-color);
  color: #FFFFFF;
  border-color: var(--primary-color);
  box-shadow: 0 12rpx 28rpx rgba(17, 24, 39, 0.14);
}

.input {
  width: 100%;
  height: 112rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  border-radius: var(--border-radius-lg);
  background: #FFFFFF;
  border: 1px solid rgba(17, 24, 39, 0.06);
  color: var(--text-main);
  font-size: 30rpx;
  font-weight: 600;
}

.tip {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}

.info-box {
  margin-bottom: 36rpx;
}

.info-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-second);
}
