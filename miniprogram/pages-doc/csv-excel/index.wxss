@import "../../app.wxss";

.mode-card {
  padding: 20rpx;
  margin-bottom: 32rpx;
}

.mode-selector {
  display: flex;
  gap: 12rpx;
  padding: 8rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
}

.mode-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-second);
  transition: all 0.3s ease;
}

.mode-item.active {
  background: #FFFFFF;
  color: var(--text-main);
  box-shadow: var(--shadow-soft);
}

.form-card {
  opacity: 0.55;
  pointer-events: none;
  transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.mode-card,
.form-active {
  opacity: 1;
  pointer-events: auto;
}

.tips-block {
  margin-top: 8rpx;
}
