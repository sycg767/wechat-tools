.picker-container {
  width: 100%;
  margin-bottom: 40rpx;
}

.picker-area {
  width: 100%;
  min-height: 400rpx;
  background: #F9FAFB;
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  box-sizing: border-box;
  transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: var(--shadow-premium);
  position: relative;
  overflow: hidden;
}

.picker-area-hover {
  background: #FFFFFF;
  border-color: rgba(0, 0, 0, 0.1);
  transform: scale(0.98) translateY(4rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.has-file {
  background: #FFFFFF;
  border: 1px solid var(--text-main);
}

.picker-icon-box {
  margin-bottom: 24rpx;
}

.picker-icon {
  width: 80rpx;
  height: 80rpx;
  position: relative;
}

.icon-upload::before, .icon-upload::after {
  content: '';
  position: absolute;
  background: #86868B;
}

.icon-upload::before {
  width: 4rpx;
  height: 40rpx;
  left: 38rpx;
  top: 10rpx;
}

.icon-upload::after {
  width: 24rpx;
  height: 24rpx;
  border-top: 4rpx solid #86868B;
  border-left: 4rpx solid #86868B;
  transform: rotate(45deg);
  left: 28rpx;
  top: 10rpx;
}

.icon-file-active {
  background: #007AFF;
  border-radius: 8rpx;
}

.picker-main-text {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.picker-sub-text {
  font-size: 26rpx;
  color: var(--text-second);
}

.file-display {
  text-align: center;
  width: 100%;
}

.file-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #007AFF;
  margin-bottom: 12rpx;
  word-break: break-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.file-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.file-size {
  font-size: 24rpx;
  color: #86868B;
}

.file-change {
  font-size: 24rpx;
  color: #007AFF;
  text-decoration: underline;
}

.picker-tips {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}

.tip-item {
  font-size: 22rpx;
  color: #C7C7CC;
  display: flex;
  align-items: center;
}

.tip-item::before {
  content: 'i';
  width: 24rpx;
  height: 24rpx;
  border: 1rpx solid #C7C7CC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
  font-size: 18rpx;
}
