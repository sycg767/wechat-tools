.progress-card {
  margin-top: 40rpx;
  padding: 40rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.progress-percentage {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 700;
}

.progress-track {
  width: 100%;
  height: 12rpx;
  background: #F2F2F7;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), #58A6FF);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.progress-tip {
  margin-top: 20rpx;
  font-size: 22rpx;
  color: var(--text-second);
  text-align: center;
}
