 .result-card {
  margin-top: 56rpx;
  padding: 48rpx;
  border-radius: var(--border-radius-apple);
  background: linear-gradient(180deg, #FFFFFF 0%, #FBFBFD 100%);
  border: var(--border-premium);
  box-shadow: var(--shadow-premium);
  animation: slideUp 0.45s cubic-bezier(0.23, 1, 0.32, 1);
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.success-icon-box {
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 20rpx;
  border-radius: 34rpx;
  background: rgba(17, 24, 39, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-icon {
  width: 38rpx;
  height: 20rpx;
  border-left: 6rpx solid var(--primary-color);
  border-bottom: 6rpx solid var(--primary-color);
  transform: rotate(-45deg);
  margin-top: -8rpx;
}

.result-title {
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-main);
}

.result-body {
  margin-bottom: 40rpx;
  padding: 30rpx 32rpx;
  border-radius: var(--border-radius-lg);
  background: var(--card-subtle);
  border: 1px solid rgba(17, 24, 39, 0.03);
}

.file-info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.file-info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--text-second);
}

.info-value {
  font-size: 24rpx;
  line-height: 1.65;
  color: var(--text-main);
  text-align: right;
  word-break: break-all;
}

.url-text {
  color: var(--text-main);
  text-decoration: underline;
}

.result-footer {
  text-align: center;
}

.share-tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: var(--text-second);
}
