.result-card {
  margin-top: 60rpx;
  border-radius: 44rpx;
  background: #FFFFFF;
  box-shadow: var(--shadow-premium);
  border: var(--border-premium);
  padding: 48rpx;
  animation: slideUp 0.6s cubic-bezier(0.23, 1, 0.32, 1);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.success-icon-box {
  width: 100rpx;
  height: 100rpx;
  background: var(--primary-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.success-icon {
  width: 40rpx;
  height: 20rpx;
  border-left: 6rpx solid var(--primary-color);
  border-bottom: 6rpx solid var(--primary-color);
  transform: rotate(-45deg);
  margin-top: -10rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
}

.result-body {
  background: #F8F9FB;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  border: 1px solid rgba(0, 0, 0, 0.02);
}

.file-info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.file-info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 24rpx;
  color: var(--text-second);
  flex-shrink: 0;
}

.info-value {
  font-size: 24rpx;
  color: var(--text-main);
  text-align: right;
  word-break: break-all;
  margin-left: 20rpx;
}

.url-text {
  color: var(--primary-color);
  text-decoration: underline;
}

.result-footer {
  text-align: center;
}

.share-tip {
  font-size: 22rpx;
  color: var(--text-second);
  margin-top: 20rpx;
}
