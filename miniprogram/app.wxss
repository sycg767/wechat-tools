/** 全局变量 **/
page {
  /* Apple-Style Premium Palette */
  --primary-color: #000000;
  --primary-light: #F2F2F7;
  --success-color: #34C759;
  --warning-color: #FF9500;
  --error-color: #FF3B30;
  
  --text-main: #1C1C1E;
  --text-second: #8E8E93;
  --text-placeholder: #C7C7CC;
  
  --bg-color: #F2F2F7;
  --card-bg: #FFFFFF;
  
  --border-radius-apple: 44rpx;
  --border-radius-pill: 100rpx;
  
  /* Sophisticated Multi-layered Shadows */
  --shadow-premium:
    0 2rpx 8rpx rgba(0, 0, 0, 0.02),
    0 10rpx 20rpx rgba(0, 0, 0, 0.04),
    0 20rpx 40rpx rgba(0, 0, 0, 0.04);
    
  --border-premium: 1px solid rgba(0, 0, 0, 0.03);
  
  background: var(--bg-color);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 48rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

/** Bento 卡片样式 **/
.card {
  background: var(--card-bg);
  border-radius: var(--border-radius-bento);
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: var(--shadow-bento);
  border: var(--border-bento);
  margin-bottom: 32rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-active {
  transform: scale(0.98);
  opacity: 0.9;
}

/** 标题样式 **/
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin: 40rpx 0 24rpx 8rpx;
  color: var(--text-main);
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--primary-color);
  margin-right: 16rpx;
  border-radius: 4rpx;
}

/** 按钮样式 **/
.btn {
  height: 110rpx;
  line-height: 110rpx;
  text-align: center;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 1rpx;
}

.btn-primary {
  background: var(--primary-color);
  color: #ffffff;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(0, 0, 0, 0.2);
}

.btn-secondary {
  background: #FFFFFF;
  color: var(--text-main);
  border: 1px solid rgba(0, 0, 0, 0.05);
  box-shadow: var(--shadow-premium);
}

.btn-hover {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-disabled {
  background: #E5E5EA;
  color: #AEAEB2;
  box-shadow: none;
}

/** 辅助类 **/
.text-center { text-align: center; }
.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }
.flex-center { display: flex; align-items: center; justify-content: center; }
